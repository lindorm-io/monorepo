{
  "name": "@lindorm-io/yaml-typing",
  "description": "YAML types generator for lindorm.io",
  "version": "0.0.2",
  "license": "AGPL-3.0-or-later",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist",
    "example": "ts-node example/logger",
    "test": "jest",
    "test:update": "jest -u --",
    "test:watch": "jest --watch --",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch"
  },
  "bin": {
    "generate-typing": "dist/program.js"
  },
  "dependencies": {
    "commander": "^9.1.0",
    "js-yaml": "^4.1.0",
    "quicktype-core": "^6.0.71"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.5"
  }
}
