// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`generateSource > attaches a MemoryCacheAdapter when cache=memory 1`] = `
"import { join } from "path";
import { logger } from "../../logger/index.js";
import { config } from "../../pylon/config.js";
import { ProteusSource, MemoryCacheAdapter } from "@lindorm/proteus";

export const source = new ProteusSource({
  driver: "postgres",
  logger: logger,
  entities: [join(import.meta.dirname, "entities")],
  migrations: [join(import.meta.dirname, "migrations")],
  url: config.postgres.url,
  cache: {
    adapter: new MemoryCacheAdapter(),
    ttl: "1m",
  },
});
"
`;

exports[`generateSource > attaches a RedisCacheAdapter to a postgres DB source when cache=redis 1`] = `
"import { join } from "path";
import { logger } from "../../logger/index.js";
import { config } from "../../pylon/config.js";
import { ProteusSource, RedisCacheAdapter } from "@lindorm/proteus";

export const source = new ProteusSource({
  driver: "postgres",
  logger: logger,
  entities: [join(import.meta.dirname, "entities")],
  migrations: [join(import.meta.dirname, "migrations")],
  url: config.postgres.url,
  cache: {
    adapter: new RedisCacheAdapter({ url: config.redis.url, keyPrefix: "postgres:cache:" }),
    ttl: "1m",
  },
});
"
`;

