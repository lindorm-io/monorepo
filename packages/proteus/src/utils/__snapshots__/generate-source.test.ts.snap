exports[`generateSource > falls back to hardcoded redis connection when configImport is absent 1`] = `
"import { join } from "path";
import { logger } from "../logger";
import { ProteusSource, RedisCacheAdapter } from "@lindorm/proteus";

export const source = new ProteusSource({
  driver: "postgres",
  logger: logger,
  entities: [join(import.meta.dirname, "entities")],
  migrations: [join(import.meta.dirname, "migrations")],
  host: "localhost",
  port: 5432,
  database: "app",
  cache: {
    adapter: new RedisCacheAdapter({ host: "localhost", port: 6379, keyPrefix: "postgres:cache:" }),
    ttl: "1m",
  },
});
"
`;

