exports[`compileAggregationPipeline > should produce $sort, $skip, and $limit stages 1`] = `
[
  {
    "$group": {
      "_id": {
        "category": "$category",
      },
      "total": {
        "$sum": "$amount",
      },
    },
  },
  {
    "$sort": {
      "category": 1,
    },
  },
  {
    "$skip": 10,
  },
  {
    "$limit": 5,
  },
  {
    "$project": {
      "_id": 0,
      "category": "$_id.category",
      "total": 1,
    },
  },
]
`;

