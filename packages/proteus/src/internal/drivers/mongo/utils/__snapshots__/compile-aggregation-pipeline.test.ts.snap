// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`compileAggregationPipeline > should add $match for having conditions 1`] = `
[
  {
    "$group": {
      "_id": {
        "category": "$category",
      },
      "total": {
        "$sum": "$amount",
      },
    },
  },
  {
    "$match": {
      "total": {
        "$gt": 100,
      },
    },
  },
  {
    "$project": {
      "_id": 0,
      "category": "$_id.category",
      "total": 1,
    },
  },
]
`;

exports[`compileAggregationPipeline > should handle COUNT(*) as $sum: 1 1`] = `
[
  {
    "$group": {
      "_id": {
        "category": "$category",
      },
      "count": {
        "$sum": 1,
      },
    },
  },
  {
    "$project": {
      "_id": 0,
      "category": "$_id.category",
      "count": 1,
    },
  },
]
`;

