// Jest Snapshot v1, https://jestjs.io/docs/snapshot-testing

exports[`generateAppendOnlyDDL (MySQL) escapes backticks in table name 1`] = `
[
  "DROP TRIGGER IF EXISTS \`proteus_ao_my\`\`table_no_update\`;",
  "CREATE TRIGGER \`proteus_ao_my\`\`table_no_update\`
  BEFORE UPDATE ON \`my\`\`table\`
  FOR EACH ROW
  SIGNAL SQLSTATE '45000'
    SET MESSAGE_TEXT = 'append-only entity: UPDATE operations are forbidden';",
  "DROP TRIGGER IF EXISTS \`proteus_ao_my\`\`table_no_delete\`;",
  "CREATE TRIGGER \`proteus_ao_my\`\`table_no_delete\`
  BEFORE DELETE ON \`my\`\`table\`
  FOR EACH ROW
  SIGNAL SQLSTATE '45000'
    SET MESSAGE_TEXT = 'append-only entity: DELETE operations are forbidden';",
]
`;

exports[`generateAppendOnlyDDL (MySQL) generates triggers for a simple table 1`] = `
[
  "DROP TRIGGER IF EXISTS \`proteus_ao_audit_log_no_update\`;",
  "CREATE TRIGGER \`proteus_ao_audit_log_no_update\`
  BEFORE UPDATE ON \`audit_log\`
  FOR EACH ROW
  SIGNAL SQLSTATE '45000'
    SET MESSAGE_TEXT = 'append-only entity: UPDATE operations are forbidden';",
  "DROP TRIGGER IF EXISTS \`proteus_ao_audit_log_no_delete\`;",
  "CREATE TRIGGER \`proteus_ao_audit_log_no_delete\`
  BEFORE DELETE ON \`audit_log\`
  FOR EACH ROW
  SIGNAL SQLSTATE '45000'
    SET MESSAGE_TEXT = 'append-only entity: DELETE operations are forbidden';",
]
`;
