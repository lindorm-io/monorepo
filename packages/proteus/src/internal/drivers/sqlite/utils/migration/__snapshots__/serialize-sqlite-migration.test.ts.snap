exports[`serializeSqliteMigration mixed operations should handle a plan with multiple operation types 1`] = `
"import type { MigrationInterface, SqlMigrationRunner } from "@lindorm/proteus";

export class BigMigration implements MigrationInterface {
  public readonly id = "00000000-0000-0000-0000-000000000000";
  public readonly ts = "2025-06-15T10:30:45.000Z";
  public readonly driver = "sqlite";

  public async up(runner: SqlMigrationRunner): Promise<void> {
    // Create table "categories"
    await runner.query(\`CREATE TABLE "categories" ("id" TEXT PRIMARY KEY, "name" TEXT NOT NULL);\`);

    // Add column on "posts"
    await runner.query(\`ALTER TABLE "posts" ADD COLUMN "category_id" TEXT;\`);

    // Create index
    await runner.query(\`CREATE INDEX "idx_posts_category_id" ON "posts" ("category_id");\`);

    // Drop index "idx_posts_legacy"
    await runner.query(\`DROP INDEX IF EXISTS "idx_posts_legacy"\`);

    // Recreate table "users"
    await runner.query(\`PRAGMA foreign_keys = OFF\`);
    await runner.transaction(async (ctx) => {
      await ctx.query(\`CREATE TABLE "_new_users" ("id" TEXT PRIMARY KEY, "name" TEXT NOT NULL, "email" TEXT UNIQUE);\`);
      await ctx.query(\`INSERT INTO "_new_users" SELECT "id", "name" FROM "users"\`);
      await ctx.query(\`DROP TABLE "users"\`);
      await ctx.query(\`ALTER TABLE "_new_users" RENAME TO "users"\`);
      await ctx.query(\`CREATE UNIQUE INDEX "idx_users_email" ON "users" ("email");\`);
    });
    await runner.query(\`PRAGMA foreign_keys = ON\`);
    await runner.query(\`PRAGMA foreign_key_check\`);
  }

  public async down(runner: SqlMigrationRunner): Promise<void> {
    // WARN: irreversible — recreate_table for "users" cannot be automatically reversed
    // WARN: irreversible — original index DDL not available for recreation
    await runner.query(\`DROP INDEX IF EXISTS "idx_posts_category_id"\`);
    // WARN: irreversible — SQLite does not support DROP COLUMN via ALTER TABLE in all versions
    await runner.query(\`DROP TABLE IF EXISTS "categories"\`);
  }
}
"
`;

