      await ctx.query(\`INSERT INTO "_new_items" SELECT "id" FROM "items"\`);
      await ctx.query(\`DROP TABLE "items"\`);
      await ctx.query(\`ALTER TABLE "_new_items" RENAME TO "items"\`);
    });
    await runner.query(\`PRAGMA foreign_keys = ON\`);
