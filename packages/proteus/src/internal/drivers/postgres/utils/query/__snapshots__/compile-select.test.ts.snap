exports[`compileSelect — non-empty includes > should emit columns from multiple included relations with distinct alias prefixes 1`] = `"SELECT "t0"."id" AS "t0_id", "t0"."name" AS "t0_name", "t0"."email_address" AS "t0_email", "t0"."age" AS "t0_age", "t0"."dept_code" AS "t0_department", "t0"."tag_id" AS "t0_tag_id", "t1"."id" AS "t1_id", "t1"."label" AS "t1_label", "t1"."active" AS "t1_active", "t2"."id" AS "t2_id", "t2"."bio" AS "t2_bio""`;

exports[`compileSelect — non-empty includes > should honour include.select and emit only the specified foreign fields 1`] = `"SELECT "t0"."id" AS "t0_id", "t0"."name" AS "t0_name", "t0"."email_address" AS "t0_email", "t0"."age" AS "t0_age", "t0"."dept_code" AS "t0_department", "t0"."tag_id" AS "t0_tag_id", "t1"."id" AS "t1_id", "t1"."label" AS "t1_label""`;

exports[`compileSelect — non-empty includes > should include all foreign entity columns with the target alias prefix 1`] = `"SELECT "t0"."id" AS "t0_id", "t0"."name" AS "t0_name", "t0"."email_address" AS "t0_email", "t0"."age" AS "t0_age", "t0"."dept_code" AS "t0_department", "t0"."tag_id" AS "t0_tag_id", "t1"."id" AS "t1_id", "t1"."label" AS "t1_label", "t1"."active" AS "t1_active""`;

exports[`compileSelect — raw selections > should compile raw selection with params 1`] = `"SELECT "t0"."id" AS "t0_id", "t0"."name" AS "t0_name", "t0"."email_address" AS "t0_email", "t0"."age" AS "t0_age", "t0"."dept_code" AS "t0_department", COALESCE($1, $2) AS "safe_name""`;

exports[`compileSelect — window functions > should compile LAG with column arg 1`] = `"SELECT "t0"."id" AS "t0_id", "t0"."name" AS "t0_name", "t0"."email_address" AS "t0_email", "t0"."age" AS "t0_age", "t0"."dept_code" AS "t0_department", LAG("t0"."age", 1) OVER (ORDER BY "t0"."name" ASC) AS "prev_age""`;

exports[`compileSelect — window functions > should compile NTILE with numeric arg 1`] = `"SELECT "t0"."id" AS "t0_id", "t0"."name" AS "t0_name", "t0"."email_address" AS "t0_email", "t0"."age" AS "t0_age", "t0"."dept_code" AS "t0_department", NTILE(4) OVER (ORDER BY "t0"."age" ASC) AS "quartile""`;

exports[`compileSelect — window functions > should compile RANK with no args and empty OVER 1`] = `"SELECT "t0"."id" AS "t0_id", "t0"."name" AS "t0_name", "t0"."email_address" AS "t0_email", "t0"."age" AS "t0_age", "t0"."dept_code" AS "t0_department", RANK() OVER (ORDER BY "t0"."age" DESC) AS "rank""`;

exports[`compileSelect — window functions > should compile ROW_NUMBER with partitionBy and orderBy 1`] = `"SELECT "t0"."id" AS "t0_id", "t0"."name" AS "t0_name", "t0"."email_address" AS "t0_email", "t0"."age" AS "t0_age", "t0"."dept_code" AS "t0_department", ROW_NUMBER() OVER (PARTITION BY "t0"."dept_code" ORDER BY "t0"."age" DESC) AS "row_num""`;

exports[`compileSelect — window functions > should compile SUM with partitionBy only (no orderBy) 1`] = `"SELECT "t0"."id" AS "t0_id", "t0"."name" AS "t0_name", "t0"."email_address" AS "t0_email", "t0"."age" AS "t0_age", "t0"."dept_code" AS "t0_department", SUM("t0"."age") OVER (PARTITION BY "t0"."dept_code") AS "dept_total""`;

exports[`compileSelect — window functions > should compile multiple window functions 1`] = `"SELECT "t0"."id" AS "t0_id", "t0"."name" AS "t0_name", "t0"."email_address" AS "t0_email", "t0"."age" AS "t0_age", "t0"."dept_code" AS "t0_department", ROW_NUMBER() OVER (ORDER BY "t0"."name" ASC) AS "rn", DENSE_RANK() OVER (PARTITION BY "t0"."dept_code" ORDER BY "t0"."age" DESC) AS "dr""`;

exports[`compileSelect — window functions > should resolve custom column name in window function 1`] = `"SELECT "t0"."id" AS "t0_id", "t0"."name" AS "t0_name", "t0"."email_address" AS "t0_email", "t0"."age" AS "t0_age", "t0"."dept_code" AS "t0_department", COUNT("t0"."email_address") OVER (PARTITION BY "t0"."dept_code") AS "email_count""`;
