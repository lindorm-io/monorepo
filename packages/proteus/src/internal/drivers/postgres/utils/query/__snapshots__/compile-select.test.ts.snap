exports[`compileSelect — FK column injection from ManyToOne joinKeys > should inject FK column (user_id) that is absent from fields list 1`] = `"SELECT "t0"."id" AS "t0_id", "t0"."title" AS "t0_title", "t0"."user_id" AS "t0_user_id""`;

