exports[`generateCommentDDL > escapes single quotes in field comment 1`] = `
[
  "COMMENT ON COLUMN "test_comment_entity"."owner" IS 'Owner''s name';",
]
`;

exports[`generateCommentDDL > escapes single quotes in table comment 1`] = `
