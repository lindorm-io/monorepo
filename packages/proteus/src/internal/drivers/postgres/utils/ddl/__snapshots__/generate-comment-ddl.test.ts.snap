  "COMMENT ON TABLE "test_comment_entity" IS 'It''s a table';",
]
`;

exports[`generateCommentDDL > generates COMMENT ON COLUMN for fields with comments 1`] = `
[
  "COMMENT ON COLUMN "test_comment_entity"."name" IS 'The display name';",
  "COMMENT ON COLUMN "test_comment_entity"."email" IS 'Primary contact email';",
]
