{
  "name": "@lindorm/proteus",
  "version": "0.4.0",
  "license": "AGPL-3.0-or-later",
  "author": "Jonn Nilsson",
  "repository": {
    "url": "https://github.com/lindorm-io/monorepo",
    "directory": "packages/proteus"
  },
  "bugs": "https://github.com/lindorm-io/monorepo/issues",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./mocks": {
      "types": "./dist/mocks/index.d.ts",
      "default": "./dist/mocks/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "mocks": [
        "dist/mocks/index.d.ts"
      ]
    }
  },
  "bin": {
    "proteus": "dist/cli.js"
  },
  "imports": {
    "#internal/*": "./dist/internal/*.js"
  },
  "scripts": {
    "build": "rimraf dist && tsc -b ./tsconfig.build.json && chmod +x dist/cli.js",
    "example:cli": "cd example && tsx ../src/cli.ts",
    "prettier": "prettier --write ./src/*",
    "test": "composed --file docker-compose.yml jest --workerIdleMemoryLimit=512MB",
    "test:ci": "jest --forceExit --workerIdleMemoryLimit=512MB",
    "test:update": "composed --file docker-compose.yml jest -u",
    "test:watch": "composed --file docker-compose.yml jest --detectOpenHandles --watch",
    "typecheck": "tsc",
    "typecheck:watch": "tsc --watch",
    "update": "ncu -i",
    "update:auto": "ncu -u",
    "verify": "npm run typecheck && npm run build && npm test"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "@lindorm/breaker": "^0.2.0",
    "@lindorm/case": "^0.1.14",
    "@lindorm/date": "^0.4.2",
    "@lindorm/errors": "^0.1.16",
    "@lindorm/is": "^0.1.14",
    "@lindorm/json-kit": "^0.5.6",
    "@lindorm/logger": "^0.5.2",
    "@lindorm/retry": "^0.2.1",
    "@lindorm/scanner": "^0.4.2",
    "@lindorm/sha": "^0.3.2",
    "@lindorm/utils": "^0.6.2",
    "commander": "^14.0.3",
    "pg-cursor": "^2.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@lindorm/aes": "^0.6.3",
    "@lindorm/amphora": "^0.3.4",
    "@lindorm/kryptos": "^0.5.3",
    "@lindorm/types": "^0.4.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/pg": "^8.18.0",
    "@types/pg-cursor": "^2.7.2",
    "better-sqlite3": "^12.6.2",
    "ioredis": "^5.10.0",
    "mongodb": "^7.1.0",
    "mysql2": "^3.19.1",
    "pg": "^8.20.0"
  },
  "peerDependencies": {
    "@lindorm/aes": "^0.6.0",
    "@lindorm/amphora": "^0.3.0",
    "better-sqlite3": ">=12.6.0",
    "ioredis": ">=5.10.0",
    "mongodb": ">=6.17.0",
    "mysql2": ">=3.19.0",
    "pg": ">=8.18.0"
  },
  "peerDependenciesMeta": {
    "@lindorm/aes": {
      "optional": true
    },
    "@lindorm/amphora": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "mongodb": {
      "optional": true
    },
    "mysql2": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  }
}
