{
  "name": "@lindorm/amphora",
  "version": "0.4.0",
  "license": "AGPL-3.0-or-later",
  "author": "Jonn Nilsson",
  "repository": {
    "url": "https://github.com/lindorm-io/monorepo",
    "directory": "packages/amphora"
  },
  "bugs": "https://github.com/lindorm-io/monorepo/issues",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./mocks": {
      "types": "./dist/mocks/index.d.ts",
      "default": "./dist/mocks/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "mocks": [
        "dist/mocks/index.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "rimraf dist && tsc -b ./tsconfig.build.json",
    "example": "ts-node example",
    "prettier": "prettier --write ./src/*",
    "test": "jest",
    "test:ci": "jest",
    "test:watch": "jest --watch --",
    "typecheck": "tsc",
    "typecheck:watch": "tsc --watch",
    "update": "ncu -i",
    "update:auto": "ncu -u",
    "verify": "npm run typecheck && npm run build && npm test"
  },
  "dependencies": {
    "@lindorm/conduit": "^0.5.0",
    "@lindorm/errors": "^0.1.17",
    "@lindorm/is": "^0.1.15",
    "@lindorm/kryptos": "^0.6.0",
    "@lindorm/utils": "^0.7.0"
  },
  "devDependencies": {
    "@lindorm/logger": "^0.5.3",
    "@lindorm/types": "^0.5.0"
  }
}
