{
  "name": "@lindorm-io/jwt",
  "description": "JWT tools for lindorm.io",
  "version": "0.9.3",
  "license": "AGPL-3.0-or-later",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rimraf dist && tsc -b ./tsconfig.build.json",
    "test": "jest --watch --",
    "test:ci": "yarn test:unit",
    "test:unit": "jest --forceExit",
    "test:unit:update": "jest --forceExit -u",
    "test:update": "yarn test:unit:update",
    "typecheck": "tsc --noEmit --watch",
    "typecheck:ci": "tsc --noEmit"
  },
  "dependencies": {
    "@lindorm-io/case": "^0.1.9",
    "@lindorm-io/common-types": "^0.3.0",
    "@lindorm-io/core": "^0.8.11",
    "@lindorm-io/errors": "^0.1.20",
    "@lindorm-io/expiry": "^0.1.6",
    "@lindorm-io/random": "^0.2.3",
    "jsonwebtoken": "^9.0.0"
  },
  "devDependencies": {
    "@lindorm-io/key-pair": "^0.6.20",
    "@types/jsonwebtoken": "^9.0.1",
    "date-fns": "^2.29.3"
  }
}
