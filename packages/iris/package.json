{
  "name": "@lindorm/iris",
  "version": "0.1.0",
  "license": "AGPL-3.0-or-later",
  "author": "Jonn Nilsson",
  "repository": {
    "url": "https://github.com/lindorm-io/monorepo",
    "directory": "packages/iris"
  },
  "bugs": "https://github.com/lindorm-io/monorepo/issues",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./mocks": {
      "types": "./dist/mocks/index.d.ts",
      "default": "./dist/mocks/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "mocks": [
        "dist/mocks/index.d.ts"
      ]
    }
  },
  "imports": {
    "#internal/*": "./dist/internal/*.js"
  },
  "scripts": {
    "build": "rimraf dist && tsc -b ./tsconfig.build.json",
    "example": "ts-node example",
    "prettier": "prettier --write ./src/*",
    "test": "composed --file docker-compose.yml jest --workerIdleMemoryLimit=512MB",
    "test:ci": "jest --forceExit --workerIdleMemoryLimit=512MB",
    "test:update": "composed --file docker-compose.yml jest -u",
    "test:watch": "composed --file docker-compose.yml jest --detectOpenHandles --watch",
    "typecheck": "tsc",
    "typecheck:watch": "tsc -w",
    "update": "ncu -i",
    "update:auto": "ncu -u",
    "verify": "npm run typecheck; npm run build; npm test"
  },
  "dependencies": {
    "@lindorm/aes": "^0.6.1",
    "@lindorm/amphora": "^0.3.3",
    "@lindorm/errors": "^0.1.14",
    "@lindorm/is": "^0.1.13",
    "@lindorm/json-kit": "^0.5.5",
    "@lindorm/logger": "^0.5.0",
    "@lindorm/random": "^0.2.2",
    "@lindorm/retry": "^0.2.0",
    "@lindorm/scanner": "^0.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@lindorm/kryptos": "^0.5.1",
    "@lindorm/types": "^0.4.0",
    "@types/amqplib": "^0.10.8",
    "amqplib": "^0.10.9",
    "ioredis": "^5.10.0",
    "kafkajs": "^2.2.4",
    "nats": "^2.29.3"
  },
  "peerDependencies": {
    "amqplib": ">=0.10.0",
    "ioredis": ">=5.10.0",
    "kafkajs": ">=2.2.0",
    "nats": ">=2.29.0"
  },
  "peerDependenciesMeta": {
    "amqplib": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "kafkajs": {
      "optional": true
    },
    "nats": {
      "optional": true
    }
  }
}
