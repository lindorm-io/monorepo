{
  "name": "@lindorm/composed",
  "version": "0.0.0",
  "license": "AGPL-3.0-or-later",
  "author": "Jonn Nilsson",
  "repository": {
    "url": "https://github.com/lindorm-io/monorepo",
    "directory": "packages/composed"
  },
  "bugs": "https://github.com/lindorm-io/monorepo/issues",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "bin": {
    "composed": "dist/cli.js"
  },
  "imports": {
    "#internal/*": "./dist/internal/*.js"
  },
  "scripts": {
    "build": "rimraf dist && tsc -b ./tsconfig.build.json && chmod +x dist/cli.js",
    "example": "ts-node example",
    "prettier": "prettier --write ./src/*",
    "test": "jest --",
    "test:ci": "jest",
    "test:smoke": "composed --file docker-compose.yml jest --config jest.config.smoke.mjs --detectOpenHandles --runInBand --no-coverage",
    "test:update": "jest -u --",
    "test:watch": "jest --watch --",
    "typecheck": "tsc",
    "typecheck:watch": "tsc -w",
    "update": "ncu -i",
    "update:auto": "ncu -u",
    "verify": "npm run typecheck; npm run build; npm test"
  },
  "dependencies": {
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/pg": "^8.16.0",
    "pg": "^8.18.0"
  }
}
