    "@lindorm-io/errors": "^0.1.20",
    "@lindorm-io/random": "^0.2.4",
    "date-fns": "^2.29.3",
    "joi": "^17.9.1",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@types/lodash": "^4.14.200"
  }
}
