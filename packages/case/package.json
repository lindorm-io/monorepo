{
  "name": "@lindorm-io/case",
  "description": "Case transform utilities for lindorm.io",
  "version": "0.1.6",
  "license": "AGPL-3.0-or-later",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rimraf dist && tsc -b ./tsconfig.build.json",
    "test": "jest",
    "test:update": "jest -u --",
    "test:watch": "jest --watch --",
    "typecheck": "tsc --noEmit --watch",
    "typecheck:ci": "tsc --noEmit"
  },
  "dependencies": {
    "@lindorm-io/core": "^0.8.8",
    "change-case": "^4.1.2"
  }
}
