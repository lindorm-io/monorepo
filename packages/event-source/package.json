{
  "name": "@lindorm-io/event-source",
  "description": "Event Source for lindorm.io",
  "version": "0.0.1",
  "license": "AGPL-3.0-or-later",
  "contributors": ["Mattias Nordberg"],
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist",
    "example": "compd --file docker-compose.yml ts-node example/app",
    "test": "yarn test:unit && yarn test:integration",
    "test:integration": "compd --file docker-compose.yml jest --runInBand --forceExit --config jest.config.integration.js --",
    "test:integration:update": "compd --file docker-compose.yml jest --runInBand --forceExit --config jest.config.integration.js -u --",
    "test:integration:watch": "compd --file docker-compose.yml jest --runInBand --forceExit --config jest.config.integration.js --watch --",
    "test:unit": "jest --forceExit --config jest.config.js --",
    "test:unit:update": "jest --forceExit --config jest.config.js -u --",
    "test:unit:watch": "jest --config jest.config.js --watch --",
    "test:update": "yarn test:unit:update && yarn test:integration:update",
    "test:watch": "yarn test:unit:watch --",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch"
  },
  "dependencies": {
    "@lindorm-io/amqp": "^0.1.0",
    "@lindorm-io/core": "^0.6.3",
    "@lindorm-io/mongo": "^0.10.0",
    "@lindorm-io/postgres": "^0.0.1",
    "@lindorm-io/redis": "^0.10.0",
    "@lindorm-io/string-blob": "^0.0.12",
    "joi": "^17.6.0",
    "lodash": "^4.17.21",
    "typeorm": "^0.3.7"
  },
  "devDependencies": {
    "@lindorm-io/winston": "^0.4.7",
    "@types/amqplib": "^0.8.2",
    "@types/ioredis-mock": "^5.6.0",
    "amqplib": "^0.10.1",
    "compd": "^4.1.1",
    "date-fns": "^2.29.1",
    "ioredis-mock": "^8.2.2",
    "mock-amqplib": "^1.8.0",
    "mongo-mock": "^4.1.0"
  }
}
