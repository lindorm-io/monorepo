{
  "name": "@lindorm-io/event-source",
  "description": "Event Source for lindorm.io",
  "version": "0.2.14",
  "license": "AGPL-3.0-or-later",
  "contributors": [
    "Jonn Nilsson",
    "Mattias Nordberg"
  ],
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rimraf dist && tsc -b ./tsconfig.build.json",
    "example": "compd --file docker-compose.yml ts-node example/app",
    "test": "yarn test:unit && compd --file docker-compose.yml yarn test:compd",
    "test:compd": "yarn test:integration && yarn test:e2e",
    "test:e2e": "jest --runInBand --forceExit --config jest.config.e2e.js --",
    "test:e2e:compd": "compd --file docker-compose.yml yarn test:e2e",
    "test:e2e:update": "jest --forceExit --config jest.config.e2e.js -u --",
    "test:e2e:watch": "jest --config jest.config.e2e.js --watch --",
    "test:integration": "jest --runInBand --forceExit --config jest.config.integration.js --",
    "test:integration:compd": "compd --file docker-compose.yml yarn test:integration",
    "test:integration:update": "jest --forceExit --config jest.config.integration.js -u --",
    "test:integration:watch": "jest --config jest.config.integration.js --watch --",
    "test:unit": "jest --forceExit --config jest.config.js --",
    "test:unit:update": "jest --forceExit --config jest.config.js -u --",
    "test:unit:watch": "jest --config jest.config.js --watch --",
    "test:update": "yarn test:unit:update && yarn test:integration:update",
    "test:watch": "yarn test:unit:watch --",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch"
  },
  "dependencies": {
    "@lindorm-io/amqp": "^0.2.15",
    "@lindorm-io/case": "^0.1.6",
    "@lindorm-io/core": "^0.8.8",
    "@lindorm-io/mongo": "^0.12.0",
    "@lindorm-io/postgres": "^0.1.15",
    "@lindorm-io/random": "^0.2.0",
    "@lindorm-io/string-blob": "^0.0.24",
    "clone": "^2.1.2",
    "joi": "^17.7.0",
    "lodash": "^4.17.21",
    "merge": "^2.1.1"
  },
  "devDependencies": {
    "@lindorm-io/core-logger": "^0.2.4",
    "@types/amqplib": "^0.10.1",
    "@types/clone": "^2.1.1",
    "@types/ioredis-mock": "^8.2.1",
    "@types/pg": "^8.6.6",
    "amqplib": "^0.10.3",
    "compd": "^4.1.1",
    "date-fns": "^2.29.3",
    "mongodb": "^4.13.0",
    "pg": "^8.8.0"
  }
}
