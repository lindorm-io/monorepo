{
  "name": "@lindorm/hermes",
  "version": "0.6.1",
  "license": "AGPL-3.0-or-later",
  "author": "Jonn Nilsson",
  "repository": {
    "url": "https://github.com/lindorm-io/monorepo",
    "directory": "packages/hermes"
  },
  "bugs": "https://github.com/lindorm-io/monorepo/issues",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "hermes": "dist/cli.js"
  },
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./mocks/jest": {
      "types": "./dist/mocks/jest.d.ts",
      "default": "./dist/mocks/jest.js"
    },
    "./mocks/vitest": {
      "types": "./dist/mocks/vitest.d.mts",
      "default": "./dist/mocks/vitest.mjs"
    }
  },
  "typesVersions": {
    "*": {
      "mocks/jest": [
        "dist/mocks/jest.d.ts"
      ],
      "mocks/vitest": [
        "dist/mocks/vitest.d.mts"
      ]
    }
  },
  "scripts": {
    "build": "rimraf dist && tsc -b ./tsconfig.build.json && chmod +x dist/cli.js",
    "example": "jest --forceExit -- banking-example",
    "prettier": "prettier --write ./src/*",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --forceExit",
    "test:ci": "NODE_OPTIONS=--experimental-vm-modules jest --forceExit",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch --detectOpenHandles --",
    "typecheck": "tsc",
    "typecheck:watch": "tsc --watch",
    "update": "ncu -i",
    "update:auto": "ncu -u",
    "verify": "npm run typecheck && npm run build && npm test"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "@lindorm/aes": "^0.6.5",
    "@lindorm/case": "^0.1.16",
    "@lindorm/date": "^0.4.4",
    "@lindorm/errors": "^0.1.18",
    "@lindorm/is": "^0.1.16",
    "@lindorm/json-kit": "^0.5.8",
    "@lindorm/kryptos": "^0.7.0",
    "@lindorm/random": "^0.2.4",
    "@lindorm/scanner": "^0.4.4",
    "@lindorm/sha": "^0.4.1",
    "@lindorm/utils": "^0.7.1",
    "commander": "^14.0.3",
    "deepmerge": "^4.3.1",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@lindorm/iris": ">=0.2.0",
    "@lindorm/logger": ">=0.5.3",
    "@lindorm/proteus": ">=0.5.0"
  },
  "devDependencies": {
    "@lindorm/iris": "^0.3.0",
    "@lindorm/logger": "^0.5.4",
    "@lindorm/proteus": "^0.5.1"
  }
}
