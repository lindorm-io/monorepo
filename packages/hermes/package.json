{
  "name": "@lindorm/hermes",
  "version": "0.3.6",
  "license": "AGPL-3.0-or-later",
  "author": "Jonn Nilsson",
  "repository": {
    "url": "https://github.com/lindorm-io/monorepo",
    "directory": "packages/hermes"
  },
  "bugs": "https://github.com/lindorm-io/monorepo/issues",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "scripts": {
    "build": "rimraf dist && tsc -b ./tsconfig.build.json",
    "example": "ts-node example/hermes.ts",
    "prettier": "prettier --write ./src/*",
    "test": "composed --file docker-compose.yml jest --forceExit --runInBand --",
    "test:ci": "jest --forceExit --runInBand",
    "test:watch": "composed --file docker-compose.yml jest --runInBand --watch --",
    "typecheck": "tsc",
    "typecheck:watch": "tsc --watch",
    "update": "ncu -i",
    "update:auto": "ncu -u",
    "verify": "npm run typecheck; npm run build; npm test"
  },
  "dependencies": {
    "@lindorm/aes": "^0.6.1",
    "@lindorm/case": "^0.1.13",
    "@lindorm/date": "^0.4.0",
    "@lindorm/is": "^0.1.13",
    "@lindorm/json-kit": "^0.5.5",
    "@lindorm/kryptos": "^0.5.1",
    "@lindorm/message": "^0.1.6",
    "@lindorm/random": "^0.2.2",
    "@lindorm/scanner": "^0.4.0",
    "@lindorm/sha": "^0.3.0",
    "deepmerge": "^4.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@lindorm/kafka": "^0.3.3",
    "@lindorm/logger": "^0.5.0",
    "@lindorm/mongo": "^0.7.1",
    "@lindorm/postgres": "^0.3.9",
    "@lindorm/rabbit": "^0.6.3",
    "@lindorm/redis": "^0.9.1"
  }
}
