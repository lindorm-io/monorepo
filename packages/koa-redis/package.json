{
  "name": "@lindorm-io/koa-redis",
  "description": "Redis Connection middleware for @lindorm-io/koa applications",
  "version": "0.6.23",
  "license": "AGPL-3.0-or-later",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist",
    "test": "yarn test:unit && yarn test:integration",
    "test:integration": "compd --file docker-compose.yml jest --config jest.config.integration.js --",
    "test:integration:update": "compd --file docker-compose.yml jest --config jest.config.integration.js -u --",
    "test:integration:watch": "compd --file docker-compose.yml jest --config jest.config.integration.js --watch --",
    "test:unit": "jest",
    "test:unit:update": "jest -u --",
    "test:unit:watch": "jest --watch --",
    "test:update": "yarn test:unit:update && yarn test:integration:update",
    "test:watch": "yarn test:unit:watch",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch"
  },
  "dependencies": {
    "@lindorm-io/case": "^0.1.4",
    "@lindorm-io/core": "^0.8.6",
    "@lindorm-io/entity": "^0.3.7",
    "@lindorm-io/errors": "^0.1.15",
    "@lindorm-io/expiry": "^0.1.1",
    "@lindorm-io/koa": "^0.15.10",
    "@lindorm-io/redis": "^0.11.11",
    "object-path": "^0.11.8"
  },
  "devDependencies": {
    "@lindorm-io/core-logger": "^0.2.1",
    "@types/express-useragent": "^1.0.2",
    "@types/ioredis": "^5.0.0",
    "@types/koa": "^2.13.5",
    "@types/koa-bodyparser": "^4.3.10",
    "@types/koa-router": "^7.4.4",
    "@types/object-path": "^0.11.1",
    "ioredis": "^5.2.5",
    "koa": "2.14.1",
    "koa-bodyparser": "^4.3.0",
    "redis-commands": "^1.7.0"
  }
}
