exports[`scaffold writePylonFile snapshot: all features + all proteus workers 1`] = `
"import { Pylon } from "@lindorm/pylon";
import { join } from "path";
import { logger } from "../logger";
import { amphora } from "./amphora";
import { config } from "./config";
import { source as proteusSource } from "../proteus/source";
import { source as irisSource } from "../iris/source";

export const pylon = new Pylon({
  logger,
  amphora,
  port: config.server.port,
  routes: join(__dirname, "..", "routes"),
  socket: {
    enabled: true,
    listeners: join(__dirname, "..", "listeners"),
  },
  rooms: { presence: true },
  proteus: proteusSource,
  kryptos: { enabled: true },
  iris: irisSource,
  queue: { enabled: true },
  webhook: { enabled: true },
  audit: {
    enabled: true,
    actor: (ctx) => ctx.state.session?.subject ?? "anonymous",
    // sanitise: (body) => body,
    // skip: (ctx) => false,
    // entities: [],
  },
  workers: join(__dirname, "..", "workers"),
  setup: async () => {
    await proteusSource.connect();
    await irisSource.connect();
  },
  teardown: async () => {
    // pylon handles proteus/iris disconnect automatically
  },
});
"
`;

exports[`scaffold writePylonFile snapshot: auth only (session auto-forced) 1`] = `
"import { Pylon } from "@lindorm/pylon";
import { join } from "path";
import { logger } from "../logger";
import { amphora } from "./amphora";
import { config } from "./config";

export const pylon = new Pylon({
  logger,
  amphora,
  port: config.server.port,
  routes: join(__dirname, "..", "routes"),
  session: {
    enabled: true,
    name: "sid",
    encrypted: true,
    httpOnly: true,
    sameSite: "lax",
    secure: false, // TODO: flip to true in production (behind HTTPS)
    expiry: "7d",
  },
  auth: {
    clientId: config.authClientId,
    clientSecret: config.authClientSecret,
    issuer: config.authIssuer,
    router: {
      pathPrefix: "/auth",
      authorize: {
        scope: ["openid", "profile", "email"],
        responseType: "code",
      },
    },
  },
  setup: async () => {
  },
  teardown: async () => {
    // pylon handles proteus/iris disconnect automatically
  },
});
"
`;

