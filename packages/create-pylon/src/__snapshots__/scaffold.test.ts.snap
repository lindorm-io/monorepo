"import { configuration } from "@lindorm/config";
import { z } from "zod";

export const config = configuration({
  node: z.object({
    env: z
      .enum(["production", "staging", "development", "test", "unknown"])
      .default("development"),
  }),
  pylon: z.object({ kek: z.string() }),
  server: z.object({ port: z.number() }),
  logger: z.object({
    level: z
      .enum(["error", "warn", "info", "verbose", "debug", "silly"])
      .default("info"),
  }),
  postgres: z.object({
    url: z.string(),
  }),
  redis: z.object({
    url: z.string(),
  }),
  rabbit: z.object({
    url: z.string(),
  }),
  auth: z.object({
    clientId: z.string(),
    clientSecret: z.string(),
    issuer: z.string(),
  }),
}, { scope: import.meta.url });
"
`;

exports[`scaffold > scaffold orchestration > all-on: postgres + redis + rabbit + sessions + auth + rateLimit + workers > pylon.ts 1`] = `
"import { Pylon } from "@lindorm/pylon";
import { join } from "path";
import { logger } from "../logger/index.js";
import { amphora } from "./amphora.js";
import { config } from "./config.js";
import { source as proteusSource } from "../proteus/postgres/source.js";
import { source as rateLimitSource } from "../proteus/redis/source.js";
import { attachSourcesMiddlewares } from "../middleware/attach-sources.js";
import { source as irisSource } from "../iris/source.js";

export const pylon = new Pylon({
  logger,
  amphora,
  name: config.npm.package.name,
  version: config.npm.package.version,
  environment: config.node.env,
  port: config.server.port,
  routes: join(import.meta.dirname, "..", "routes"),
  httpMiddleware: [...attachSourcesMiddlewares],
  socket: {
    enabled: true,
    listeners: join(import.meta.dirname, "..", "listeners"),
    middleware: [...attachSourcesMiddlewares],
  },
  rooms: { presence: true },
  proteus: proteusSource,
  kryptos: { enabled: true },
  iris: irisSource,
  queue: { enabled: true },
  webhook: { enabled: true },
  audit: {
    enabled: true,
    // sanitise: (body) => body,
    // skip: (ctx) => false,
    // entities: [],
  },
  session: {
    enabled: true,
    proteus: rateLimitSource,
    name: "sid",
    encrypted: true,
    httpOnly: true,
    sameSite: "lax",
    secure: false, // TODO: flip to true in production (behind HTTPS)
    expiry: "7d",
  },
  auth: {
    clientId: config.auth.clientId,
    clientSecret: config.auth.clientSecret,
    issuer: config.auth.issuer,
    router: {
      pathPrefix: "/auth",
      authorize: {
        scope: ["openid", "profile", "email"],
        responseType: "code",
      },
    },
  },
  rateLimit: {
    enabled: true,
    proteus: rateLimitSource,
    strategy: "fixed",
    window: "1m",
    max: 60,
    // TODO: tune strategy/window/max for your traffic
  },
  workers: join(import.meta.dirname, "..", "workers"),
  setup: async () => {
    await proteusSource.connect();
    await rateLimitSource.connect();
    await irisSource.connect();
  },
  teardown: async () => {
    // pylon handles proteus/iris disconnect automatically
  },
});
"
`;

