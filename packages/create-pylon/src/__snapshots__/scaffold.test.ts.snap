exports[`scaffold > scaffold orchestration > multi-driver ctx extension > emits ExtraSources type and attach-sources middleware when 2+ drivers > attach-sources.ts 1`] = `
"import { createAttachProteusSourceMiddleware } from "@lindorm/pylon";
import type { ServerHttpMiddleware } from "../types/context.js";
import { source as redisSource } from "../proteus/redis/source.js";
import { source as memorySource } from "../proteus/memory/source.js";

/**
 * Pylon middleware instances that mount the non-primary Proteus sources on
 * the request context as \`ctx.<driver>\`. Each entry is produced by the
 * public \`createAttachProteusSourceMiddleware\` factory from \`@lindorm/pylon\`.
 *
 * Use via pylon options:
 *
 *     new Pylon({ httpMiddleware: [...attachSourcesMiddlewares] })
 */
export const attachSourcesMiddlewares: Array<ServerHttpMiddleware> = [
  createAttachProteusSourceMiddleware({ key: "redis", source: redisSource }),
  createAttachProteusSourceMiddleware({ key: "memory", source: memorySource }),
];
"
`;

exports[`scaffold > scaffold orchestration > multi-driver ctx extension > emits ExtraSources type and attach-sources middleware when 2+ drivers > context.ts 1`] = `
"import type {
  PylonHandler,
  PylonHttpContext,
  PylonHttpMiddleware,
  PylonSocketContext,
  PylonSocketMiddleware,
} from "@lindorm/pylon";
import type { IProteusSession } from "@lindorm/proteus";
import type { z, ZodType } from "zod";

type ExtraSources = {
  redis?: IProteusSession;
  memory?: IProteusSession;
};

export type ServerHttpContext<Data = any> = PylonHttpContext<Data> & ExtraSources;

export type ServerSocketContext<Payload = any> = PylonSocketContext<Payload> & ExtraSources;

export type ServerHttpMiddleware<C extends ServerHttpContext = ServerHttpContext> =
  PylonHttpMiddleware<C>;

export type ServerSocketMiddleware<C extends ServerSocketContext = ServerSocketContext> =
  PylonSocketMiddleware<C>;

// TODO: extend Data / State / Payload here to match your application's shape.
export type ServerHandler<
  Schema extends ZodType = ZodType<any>,
  Body = any,
> = PylonHandler<ServerHttpContext<z.infer<Schema>>, Body>;

export type ServerSocketHandler<Schema extends ZodType = ZodType<any>> =
  PylonSocketMiddleware<ServerSocketContext<z.infer<Schema>>>;
"
`;

