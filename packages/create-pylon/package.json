{
  "name": "@lindorm/create-pylon",
  "version": "0.1.0",
  "license": "AGPL-3.0-or-later",
  "author": "Jonn Nilsson",
  "repository": {
    "url": "https://github.com/lindorm-io/monorepo",
    "directory": "packages/create-pylon"
  },
  "bugs": "https://github.com/lindorm-io/monorepo/issues",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "create-pylon": "dist/cli.js"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "rimraf dist && tsc -b ./tsconfig.build.json && chmod +x dist/cli.js",
    "prettier": "prettier --write ./src/*",
    "test": "jest",
    "test:ci": "jest",
    "test:update": "jest -u --",
    "test:watch": "jest --watch --",
    "typecheck": "tsc",
    "typecheck:watch": "tsc -w",
    "update": "ncu -i",
    "update:auto": "ncu -u",
    "verify": "npm run typecheck; npm run build; npm test"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "@lindorm/case": "^0.1.16",
    "@lindorm/iris": "^0.3.0",
    "@lindorm/kryptos": "^0.7.0",
    "@lindorm/logger": "^0.5.4",
    "@lindorm/proteus": "^0.5.1",
    "@lindorm/types": "^0.5.0",
    "commander": "^14.0.3",
    "cross-spawn": "^7.0.6"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6"
  }
}
