{
  "name": "@lindorm/create-pylon",
  "version": "0.3.0",
  "license": "AGPL-3.0-or-later",
  "author": "Jonn Nilsson",
  "repository": {
    "url": "https://github.com/lindorm-io/monorepo",
    "directory": "packages/create-pylon"
  },
  "bugs": "https://github.com/lindorm-io/monorepo/issues",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "create-pylon": "dist/cli.js"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "type": "module",
  "typings": "dist/index.d.ts",
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "rimraf dist && tsc -b ./tsconfig.build.json && chmod +x dist/cli.js",
    "prettier": "prettier --write ./src/*",
    "test": "vitest run",
    "test:unit": "vitest run --exclude '**/*.integration.test.ts'",
    "test:update": "vitest run -u",
    "test:watch": "vitest",
    "typecheck": "tsc",
    "typecheck:watch": "tsc -w",
    "update": "ncu -i",
    "update:auto": "ncu -u",
    "verify": "npm run typecheck; npm run build; npm test"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "@lindorm/case": "^0.2.0",
    "@lindorm/iris": "^0.4.0",
    "@lindorm/kryptos": "^0.8.0",
    "@lindorm/logger": "^0.6.0",
    "@lindorm/proteus": "^0.6.0",
    "@lindorm/types": "^0.6.0",
    "commander": "^14.0.3",
    "cross-spawn": "^7.0.6"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  }
}
