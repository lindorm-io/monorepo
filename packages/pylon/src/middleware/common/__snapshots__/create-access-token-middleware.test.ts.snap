exports[`createAccessTokenMiddleware > DPoP (HTTP) > passes DPoP header to aegis and stores verified token 1`] = `
{
  "dpop": {
    "httpMethod": "POST",
    "httpUri": "https://api.example.com/orders",
    "issuedAt": 2024-01-01T08:00:00.000Z,
    "thumbprint": "proof-thumbprint",
    "tokenId": "proof-jti",
  },
  "header": {
    "tokenType": "access_token",
  },
  "payload": {
    "confirmation": {
      "thumbprint": "proof-thumbprint",
    },
    "subject": "verified_subject",
  },
}
`;

