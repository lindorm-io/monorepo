{
  "name": "@lindorm/pylon",
  "version": "0.9.0",
  "license": "AGPL-3.0-or-later",
  "author": "Jonn Nilsson",
  "repository": {
    "url": "https://github.com/lindorm-io/monorepo",
    "directory": "packages/pylon"
  },
  "bugs": "https://github.com/lindorm-io/monorepo/issues",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "pylon": "dist/cli.js"
  },
  "type": "module",
  "typings": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./mocks": {
      "types": "./dist/mocks/index.d.ts",
      "default": "./dist/mocks/index.js"
    }
  },
  "scripts": {
    "build": "rimraf dist && tsc -b ./tsconfig.build.json && chmod +x dist/cli.js",
    "example": "ts-node example/index.ts",
    "example:jwks": "ts-node example/jwks",
    "example:socket": "ts-node example/socket",
    "prettier": "prettier --write ./src/*",
    "test": "vitest run",
    "test:unit": "vitest run --exclude '**/*.integration.test.ts'",
    "test:watch": "vitest",
    "typecheck": "tsc",
    "typecheck:watch": "tsc --watch",
    "update": "ncu -i",
    "update:auto": "ncu -u",
    "verify": "npm run typecheck && npm run build && npm test"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "@lindorm/aegis": "^0.6.0",
    "@lindorm/b64": "^0.1.10",
    "@lindorm/case": "^0.1.16",
    "@lindorm/conduit": "^0.5.1",
    "@lindorm/date": "^0.4.4",
    "@lindorm/enums": "^0.1.8",
    "@lindorm/errors": "^0.1.18",
    "@lindorm/is": "^0.1.16",
    "@lindorm/kryptos": "^0.7.0",
    "@lindorm/middleware": "^0.1.9",
    "@lindorm/pkce": "^0.1.14",
    "@lindorm/scanner": "^0.4.4",
    "@lindorm/sha": "^0.4.1",
    "@lindorm/types": "^0.5.0",
    "@lindorm/url": "^0.1.17",
    "@lindorm/utils": "^0.7.1",
    "@lindorm/worker": "^0.4.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "busboy": "^1.6.0",
    "co-body": "^6.2.0",
    "commander": "^14.0.3",
    "formidable": "^3.5.4",
    "koa": "^3.1.2",
    "koa-router": "^14.0.0",
    "object-path": "^0.11.8",
    "socket.io": "^4.8.3"
  },
  "peerDependencies": {
    "@lindorm/amphora": ">=0.4.0",
    "@lindorm/hermes": ">=0.6.0",
    "@lindorm/iris": ">=0.2.0",
    "@lindorm/logger": ">=0.5.0",
    "@lindorm/proteus": ">=0.5.0"
  },
  "peerDependenciesMeta": {
    "@lindorm/hermes": {
      "optional": true
    },
    "@lindorm/iris": {
      "optional": true
    },
    "@lindorm/proteus": {
      "optional": true
    }
  },
  "devDependencies": {
    "@lindorm/amphora": "^0.4.1",
    "@lindorm/hermes": "^0.6.1",
    "@lindorm/iris": "^0.3.0",
    "@lindorm/logger": "^0.5.4",
    "@lindorm/proteus": "^0.5.1",
    "@lindorm/zephyr": "^0.1.1",
    "@types/busboy": "^1.5.4",
    "@types/co-body": "^6.1.3",
    "@types/formidable": "^3.5.0",
    "@types/ioredis": "^5.0.0",
    "@types/keygrip": "^1.0.6",
    "@types/koa": "^3.0.1",
    "@types/koa-router": "^7.4.9",
    "@types/object-path": "^0.11.4",
    "socket.io-client": "^4.8.3",
    "zod": "^4.3.6"
  }
}
