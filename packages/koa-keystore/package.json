{
  "name": "@lindorm-io/koa-keystore",
  "description": "Keystore middleware for @lindorm-io/koa applications",
  "version": "0.9.22",
  "license": "AGPL-3.0-or-later",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b ./tsconfig.build.json",
    "clean": "rimraf dist",
    "test": "yarn test:unit && yarn test:integration",
    "test:integration": "compd --file docker-compose.yml jest --config jest.config.integration.js --",
    "test:integration:update": "compd --file docker-compose.yml jest --config jest.config.integration.js -u --",
    "test:integration:watch": "compd --file docker-compose.yml jest --config jest.config.integration.js --watch --",
    "test:unit": "jest --config jest.config.js --",
    "test:unit:update": "jest --config jest.config.js -u --",
    "test:unit:watch": "jest --config jest.config.js --watch --",
    "test:update": "yarn test:unit:update && yarn test:integration:update",
    "test:watch": "yarn test:unit:watch --",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch"
  },
  "dependencies": {
    "@lindorm-io/axios": "^0.5.10",
    "@lindorm-io/core": "^0.8.7",
    "@lindorm-io/errors": "^0.1.15",
    "@lindorm-io/expiry": "^0.1.1",
    "@lindorm-io/key-pair": "^0.6.15",
    "@lindorm-io/koa": "^0.15.11",
    "@lindorm-io/mongo": "^0.11.13",
    "@lindorm-io/redis": "^0.11.12",
    "@lindorm-io/retry": "^0.1.1",
    "joi": "^17.7.0"
  },
  "devDependencies": {
    "@lindorm-io/core-logger": "^0.2.2",
    "@types/express-useragent": "^1.0.2",
    "@types/ioredis": "^5.0.0",
    "@types/ioredis-mock": "^8.2.1",
    "@types/koa": "^2.13.5",
    "@types/koa-bodyparser": "^4.3.10",
    "@types/koa-router": "^7.4.4",
    "compd": "^4.1.1",
    "koa": "^2.14.1",
    "koa-bodyparser": "^4.3.0",
    "mongodb": "^4.13.0",
    "nock": "^13.3.0"
  }
}
