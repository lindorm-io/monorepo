{
  "name": "@lindorm-io/koa",
  "description": "Koa App & Router for lindorm.io",
  "version": "0.17.0",
  "license": "AGPL-3.0-or-later",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rimraf dist && tsc -b ./tsconfig.build.json",
    "test": "jest --watch --",
    "test:ci": "yarn test:unit",
    "test:unit": "jest --forceExit",
    "test:unit:update": "jest --forceExit -u",
    "test:update": "yarn test:unit:update",
    "typecheck": "tsc --noEmit --watch",
    "typecheck:ci": "tsc --noEmit"
  },
  "dependencies": {
    "@lindorm-io/case": "^0.1.9",
    "@lindorm-io/common-types": "^0.3.0",
    "@lindorm-io/core": "^0.8.11",
    "@lindorm-io/errors": "^0.1.20",
    "@lindorm-io/retry": "^0.1.5",
    "@lindorm-io/structure-scanner": "^0.1.0",
    "joi": "^17.9.1",
    "koa": "2.14.1",
    "koa-bodyparser": "4.4.0",
    "koa-router": "12.0.0",
    "koa-useragent": "4.1.0",
    "object-path": "^0.11.8",
    "socket.io": "^4.6.1"
  },
  "devDependencies": {
    "@lindorm-io/core-logger": "^0.2.7",
    "@lindorm-io/url": "^0.2.10",
    "@types/express-useragent": "^1.0.2",
    "@types/koa": "^2.13.6",
    "@types/koa-bodyparser": "^4.3.10",
    "@types/koa-router": "^7.4.4",
    "@types/object-path": "^0.11.1"
  }
}
