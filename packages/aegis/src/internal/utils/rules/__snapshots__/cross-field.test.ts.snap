exports[`crossField > fails when expiresAt <= issuedAt 1`] = `
[
  {
    "key": "expiresAt",
    "message": "expiresAt (exp) must be after issuedAt (iat)",
  },
]
`;

exports[`crossField > fails when notBefore > expiresAt 1`] = `
[
  {
    "key": "notBefore",
    "message": "notBefore (nbf) must be at or before expiresAt (exp)",
  },
]
`;
