// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`cnfShape > fails on an unknown cnf member 1`] = `
[
  {
    "key": "cnf.surprise",
    "message": "Unknown cnf member "surprise"",
  },
]
`;

exports[`cnfShape > fails when cnf is not an object 1`] = `
[
  {
    "key": "cnf",
    "message": "cnf must be an object",
  },
]
`;

exports[`cnfShape > fails when jkt is the wrong byte length 1`] = `
[
  {
    "key": "cnf.jkt",
    "message": "cnf.jkt must be a base64url SHA-256 (32-byte) thumbprint",
  },
]
`;
