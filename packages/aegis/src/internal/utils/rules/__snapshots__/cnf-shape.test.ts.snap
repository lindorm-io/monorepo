// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`cnfShape > fails on an unknown cnf member 1`] = `
[
  {
    "key": "confirmation.surprise",
    "message": "Unknown confirmation member "surprise"",
  },
]
`;

exports[`cnfShape > fails when cnf is not an object 1`] = `
[
  {
    "key": "confirmation",
    "message": "confirmation (cnf) must be an object",
  },
]
`;

exports[`cnfShape > fails when jkt is the wrong byte length 1`] = `
[
  {
    "key": "confirmation.thumbprint",
    "message": "confirmation.thumbprint (cnf.jkt) must be a base64url SHA-256 (32-byte) thumbprint",
  },
]
`;
