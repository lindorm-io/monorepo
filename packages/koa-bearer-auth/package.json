{
  "name": "@lindorm-io/koa-bearer-auth",
  "description": "Bearer Auth middleware for @lindorm-io/koa applications",
  "version": "0.4.7",
  "license": "AGPL-3.0-or-later",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rimraf dist && tsc -b ./tsconfig.build.json",
    "test": "jest --watch --",
    "test:ci": "yarn test:unit",
    "test:unit": "jest --forceExit",
    "test:unit:update": "jest --forceExit -u",
    "test:update": "yarn test:unit:update",
    "typecheck": "tsc --noEmit --watch",
    "typecheck:ci": "tsc --noEmit"
  },
  "dependencies": {
    "@lindorm-io/common-types": "^0.3.3",
    "@lindorm-io/core": "^0.8.11",
    "@lindorm-io/errors": "^0.1.21",
    "@lindorm-io/jwt": "^0.11.1",
    "@lindorm-io/key-pair": "^0.8.0",
    "@lindorm-io/koa": "^0.17.3",
    "@lindorm-io/koa-jwt": "^0.6.7",
    "object-path": "^0.11.8"
  },
  "devDependencies": {
    "@lindorm-io/core-logger": "^0.2.9",
    "@types/express-useragent": "^1.0.4",
    "@types/koa": "^2.13.10",
    "@types/koa-bodyparser": "^4.3.11",
    "@types/koa-router": "^7.4.6",
    "@types/object-path": "^0.11.3",
    "koa": "^2.14.2",
    "koa-bodyparser": "^4.4.1"
  }
}
