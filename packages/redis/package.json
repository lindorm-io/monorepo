{
  "name": "@lindorm-io/redis",
  "description": "Redis cache tools lindorm.io packages",
  "version": "0.12.1",
  "license": "AGPL-3.0-or-later",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rimraf dist && tsc -b ./tsconfig.build.json",
    "test": "jest --watch --",
    "test:ci": "yarn test:unit && yarn test:integration",
    "test:integration": "compd --file docker-compose.yml jest --forceExit --config jest.config.integration.js",
    "test:integration:update": "compd --file docker-compose.yml jest --forceExit --config jest.config.integration.js -u",
    "test:unit": "jest --forceExit",
    "test:unit:update": "jest --forceExit -u",
    "test:update": "yarn test:unit:update && yarn test:integration:update",
    "typecheck": "tsc --noEmit --watch",
    "typecheck:ci": "tsc --noEmit"
  },
  "dependencies": {
    "@lindorm-io/case": "^0.1.7",
    "@lindorm-io/core": "^0.8.9",
    "@lindorm-io/core-connection": "^0.1.17",
    "@lindorm-io/entity": "^0.3.10",
    "@lindorm-io/errors": "^0.1.18",
    "@lindorm-io/string-blob": "^0.0.25",
    "date-fns": "^2.29.3",
    "ioredis": "^5.3.1",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@lindorm-io/core-logger": "^0.2.5",
    "@types/ioredis": "^5.0.0",
    "@types/ioredis-mock": "^8.2.1",
    "@types/lodash": "^4.14.191",
    "compd": "^4.1.1",
    "ioredis-mock": "^8.2.7",
    "redis-commands": "^1.7.0"
  }
}
