{
  "name": "@lindorm-io/redis",
  "description": "Redis and Cache tools lindorm.io packages",
  "version": "0.9.2",
  "license": "AGPL-3.0-or-later",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist",
    "test": "yarn test:integration",
    "test:integration": "compd --file docker-compose.yml jest --config jest.config.integration.js --",
    "test:integration:update": "compd --file docker-compose.yml jest --config jest.config.integration.js -u --",
    "test:integration:watch": "compd --file docker-compose.yml jest --config jest.config.integration.js --watch --",
    "test:update": "yarn test:integration:update",
    "test:watch": "yarn test:integration:watch",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch"
  },
  "dependencies": {
    "@lindorm-io/core": "^0.6.3",
    "@lindorm-io/core-connection": "^0.0.1",
    "@lindorm-io/entity": "^0.3.4",
    "@lindorm-io/errors": "^0.1.13",
    "@lindorm-io/string-blob": "^0.0.12",
    "date-fns": "^2.28.0",
    "ioredis": "^5.0.6",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@lindorm-io/winston": "^0.4.6",
    "@types/ioredis": "^4.28.7",
    "@types/lodash": "^4.14.182",
    "compd": "^4.1.1",
    "redis-commands": "^1.7.0"
  }
}
