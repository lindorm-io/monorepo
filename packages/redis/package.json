{
  "name": "@lindorm-io/redis",
  "description": "Redis and Cache tools lindorm.io packages",
  "version": "0.5.0",
  "license": "AGPL-3.0-or-later",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist",
    "test": "yarn test:unit && yarn test:integration",
    "test:integration": "compd --file docker-compose.yml jest --config jest.config.integration.js",
    "test:unit": "jest",
    "test:watch": "jest --watch --",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch"
  },
  "dependencies": {
    "@lindorm-io/core": "^0.2.12",
    "@lindorm-io/entity": "^0.3.0",
    "@lindorm-io/errors": "^0.1.10",
    "@lindorm-io/string-blob": "0.0.2",
    "@lindorm-io/winston": "^0.1.9",
    "ioredis": "^4.28.2",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@types/ioredis": "^4.28.7",
    "@types/ioredis-mock": "^5.6.0",
    "@types/lodash": "^4.14.181",
    "compd": "^4.0.0",
    "ioredis-mock": "^5.8.1",
    "redis-commands": "^1.7.0"
  }
}
