{
  "name": "@lindorm/kryptos",
  "version": "0.7.0",
  "license": "AGPL-3.0-or-later",
  "author": "Jonn Nilsson",
  "repository": {
    "url": "https://github.com/lindorm-io/monorepo",
    "directory": "packages/kryptos"
  },
  "bugs": "https://github.com/lindorm-io/monorepo/issues",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./mocks": {
      "types": "./dist/mocks/index.d.ts",
      "default": "./dist/mocks/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "mocks": [
        "dist/mocks/index.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "rimraf dist && tsc -b ./tsconfig.build.json && chmod +x dist/cli.js",
    "example": "ts-node example",
    "prettier": "prettier --write ./src/*",
    "test": "jest",
    "test:ci": "jest",
    "test:watch": "jest --watch --",
    "typecheck": "tsc",
    "typecheck:watch": "tsc --watch",
    "update": "ncu -i",
    "update:auto": "ncu -u",
    "verify": "npm run typecheck && npm run build && npm test"
  },
  "bin": {
    "kryptos": "dist/cli.js"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "@lindorm/b64": "^0.1.10",
    "@lindorm/case": "^0.1.16",
    "@lindorm/date": "^0.4.4",
    "@lindorm/errors": "^0.1.18",
    "@lindorm/is": "^0.1.16",
    "@lindorm/random": "^0.2.4",
    "@lindorm/sha": "^0.4.1",
    "@lindorm/utils": "^0.7.1",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@lindorm/types": "^0.5.0",
    "@peculiar/x509": "1.14.3"
  }
}
