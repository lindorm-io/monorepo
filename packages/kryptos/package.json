{
  "name": "@lindorm/kryptos",
  "version": "0.8.1",
  "license": "AGPL-3.0-or-later",
  "author": "Jonn Nilsson",
  "repository": {
    "url": "https://github.com/lindorm-io/monorepo",
    "directory": "packages/kryptos"
  },
  "bugs": "https://github.com/lindorm-io/monorepo/issues",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "bin": {
    "kryptos": "dist/cli.js"
  },
  "type": "module",
  "typings": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./mocks/jest": {
      "types": "./dist/mocks/jest.d.ts",
      "default": "./dist/mocks/jest.js"
    },
    "./mocks/vitest": {
      "types": "./dist/mocks/vitest.d.ts",
      "default": "./dist/mocks/vitest.js"
    },
    "./fixtures": {
      "types": "./dist/fixtures/index.d.ts",
      "default": "./dist/fixtures/index.js"
    }
  },
  "scripts": {
    "build": "rimraf dist && tsc -b ./tsconfig.build.json && chmod +x dist/cli.js",
    "example": "ts-node example",
    "prettier": "prettier --write ./src/*",
    "test": "vitest run",
    "test:unit": "vitest run --exclude '**/*.integration.test.ts'",
    "test:watch": "vitest",
    "typecheck": "tsc",
    "typecheck:watch": "tsc --watch",
    "update": "ncu -i",
    "update:auto": "ncu -u",
    "verify": "npm run typecheck && npm run build && npm test"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "@lindorm/b64": "^0.2.1",
    "@lindorm/case": "^0.2.1",
    "@lindorm/date": "^0.5.1",
    "@lindorm/errors": "^0.2.1",
    "@lindorm/is": "^0.2.1",
    "@lindorm/random": "^0.3.1",
    "@lindorm/sha": "^0.5.1",
    "@lindorm/types": "^0.6.1",
    "@lindorm/utils": "^0.8.1",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@peculiar/x509": "1.14.3"
  }
}
