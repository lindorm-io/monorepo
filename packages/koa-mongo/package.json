{
  "name": "@lindorm-io/koa-mongo",
  "description": "Mongo repository middleware for @lindorm-io/koa applications",
  "version": "0.9.3",
  "license": "AGPL-3.0-or-later",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rimraf dist && tsc -b ./tsconfig.build.json",
    "test": "jest --watch --",
    "test:ci": "yarn test:unit",
    "test:unit": "jest --forceExit",
    "test:unit:update": "jest --forceExit -u",
    "test:update": "yarn test:unit:update",
    "typecheck": "tsc --noEmit --watch",
    "typecheck:ci": "tsc --noEmit"
  },
  "dependencies": {
    "@lindorm-io/case": "^0.1.9",
    "@lindorm-io/entity": "^0.3.12",
    "@lindorm-io/errors": "^0.1.20",
    "@lindorm-io/koa": "^0.16.3",
    "@lindorm-io/mongo": "^0.12.3",
    "object-path": "^0.11.8"
  },
  "devDependencies": {
    "@lindorm-io/core-logger": "^0.2.7",
    "@types/express-useragent": "^1.0.2",
    "@types/jsonwebtoken": "^9.0.1",
    "@types/koa": "^2.13.6",
    "@types/koa-bodyparser": "^4.3.10",
    "@types/koa-router": "^7.4.4",
    "@types/object-path": "^0.11.1",
    "koa": "^2.14.1",
    "koa-bodyparser": "^4.4.0"
  }
}
