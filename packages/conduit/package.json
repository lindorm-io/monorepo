{
  "name": "@lindorm/conduit",
  "version": "0.9.0",
  "license": "AGPL-3.0-or-later",
  "author": "Jonn Nilsson",
  "repository": {
    "url": "https://github.com/lindorm-io/monorepo",
    "directory": "packages/conduit"
  },
  "bugs": "https://github.com/lindorm-io/monorepo/issues",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "typings": "dist/index.d.ts",
  "scripts": {
    "build": "rimraf dist && tsc -b ./tsconfig.build.json",
    "example": "ts-node example",
    "prettier": "prettier --write ./src/*",
    "test": "vitest run",
    "test:unit": "vitest run --exclude '**/*.integration.test.ts'",
    "test:watch": "vitest",
    "typecheck": "tsc",
    "typecheck:watch": "tsc --watch",
    "update": "ncu -i",
    "update:auto": "ncu -u",
    "verify": "npm run typecheck && npm run build && npm test"
  },
  "dependencies": {
    "@lindorm/breaker": "^0.4.2",
    "@lindorm/case": "^0.2.4",
    "@lindorm/enums": "^0.2.1",
    "@lindorm/errors": "^0.5.0",
    "@lindorm/is": "^0.2.4",
    "@lindorm/middleware": "^0.2.1",
    "@lindorm/random": "^0.4.0",
    "@lindorm/retry": "^0.3.4",
    "@lindorm/types": "^0.9.0",
    "@lindorm/url": "^0.2.4",
    "@lindorm/utils": "^0.9.0",
    "axios": "^1.15.0",
    "form-data": "^4.0.5"
  },
  "peerDependencies": {
    "@lindorm/logger": ">=0.5.0",
    "zod": ">=4.3.6"
  },
  "peerDependenciesMeta": {
    "@lindorm/logger": {
      "optional": true
    }
  },
  "devDependencies": {
    "@lindorm/logger": "^0.6.6",
    "zod": "^4.4.3"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  }
}
