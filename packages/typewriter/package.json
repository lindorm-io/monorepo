{
  "name": "@lindorm/typewriter",
  "version": "0.1.6",
  "license": "AGPL-3.0-or-later",
  "author": "Jonn Nilsson",
  "repository": {
    "url": "https://github.com/lindorm-io/monorepo",
    "directory": "packages/typewriter"
  },
  "bugs": "https://github.com/lindorm-io/monorepo/issues",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "imports": {
    "#internal/*": "./dist/internal/*.js"
  },
  "scripts": {
    "build": "rimraf dist && tsc -b ./tsconfig.build.json && chmod +x dist/cli.js",
    "example": "ts-node example",
    "prettier": "prettier --write ./src/*",
    "test": "jest",
    "test:ci": "jest",
    "test:watch": "jest --watch --",
    "typecheck": "tsc",
    "typecheck:watch": "tsc --watch",
    "update": "ncu -i",
    "update:auto": "ncu -u",
    "verify": "npm run typecheck && npm run build && npm test"
  },
  "bin": {
    "typewriter": "dist/cli.js"
  },
  "dependencies": {
    "@lindorm/case": "^0.1.15",
    "@lindorm/is": "^0.1.15",
    "@lindorm/logger": "^0.5.3",
    "commander": "^14.0.3",
    "js-yaml": "^4.1.1",
    "quicktype-core": "^23.2.6"
  }
}
