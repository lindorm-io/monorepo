{
  "name": "@lindorm/typewriter",
  "version": "0.2.2",
  "license": "AGPL-3.0-or-later",
  "author": "Jonn Nilsson",
  "repository": {
    "url": "https://github.com/lindorm-io/monorepo",
    "directory": "packages/typewriter"
  },
  "bugs": "https://github.com/lindorm-io/monorepo/issues",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "typings": "dist/index.d.ts",
  "scripts": {
    "build": "rimraf dist && tsc -b ./tsconfig.build.json && chmod +x dist/cli.js",
    "example": "ts-node example",
    "prettier": "prettier --write ./src/*",
    "test": "vitest run",
    "test:unit": "vitest run --exclude '**/*.integration.test.ts'",
    "test:watch": "vitest",
    "typecheck": "tsc",
    "typecheck:watch": "tsc --watch",
    "update": "ncu -i",
    "update:auto": "ncu -u",
    "verify": "npm run typecheck && npm run build && npm test"
  },
  "bin": {
    "typewriter": "dist/cli.js"
  },
  "dependencies": {
    "@lindorm/case": "^0.2.1",
    "@lindorm/is": "^0.2.1",
    "@lindorm/logger": "^0.6.2",
    "commander": "^14.0.3",
    "js-yaml": "^4.1.1",
    "quicktype-core": "^23.2.6"
  },
  "devDependencies": {
    "zod": "^4.3.6"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  }
}
