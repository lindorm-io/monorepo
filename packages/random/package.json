{
  "name": "@lindorm/random",
  "version": "0.2.3",
  "license": "AGPL-3.0-or-later",
  "author": "Jonn Nilsson",
  "repository": {
    "url": "https://github.com/lindorm-io/monorepo",
    "directory": "packages/random"
  },
  "bugs": "https://github.com/lindorm-io/monorepo/issues",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "imports": {
    "#internal/*": "./dist/internal/*.js"
  },
  "scripts": {
    "build": "rimraf dist && tsc -b ./tsconfig.build.json",
    "example": "ts-node example/string.ts",
    "example:id": "ts-node example/random-id.ts",
    "example:number": "ts-node example/random-number.ts",
    "example:string": "ts-node example/random-string.ts",
    "prettier": "prettier --write ./src/*",
    "test": "jest",
    "test:ci": "jest",
    "test:watch": "jest --watch --",
    "typecheck": "tsc",
    "typecheck:watch": "tsc --watch",
    "update": "ncu -i",
    "update:auto": "ncu -u",
    "verify": "npm run typecheck && npm run build && npm test"
  }
}
