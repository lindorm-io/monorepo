{
  "name": "@lindorm-io/node-server",
  "description": "Lindorm Node Server",
  "version": "0.4.18",
  "license": "AGPL-3.0-or-later",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist",
    "test": "yarn test:unit && yarn test:integration",
    "test:integration": "compd --file docker-compose.yml jest --forceExit --config jest.config.integration.js --",
    "test:integration:update": "compd --file docker-compose.yml jest --forceExit --config jest.config.integration.js -u --",
    "test:integration:watch": "compd --file docker-compose.yml jest --forceExit --config jest.config.integration.js --watch --",
    "test:unit": "jest --config jest.config.js --",
    "test:unit:update": "jest --config jest.config.js -u --",
    "test:unit:watch": "jest --config jest.config.js --watch --",
    "test:update": "yarn test:unit:update && yarn test:integration:update",
    "test:watch": "yarn test:unit:watch --",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch"
  },
  "dependencies": {
    "@lindorm-io/amqp": "^0.2.3",
    "@lindorm-io/axios": "^0.5.0",
    "@lindorm-io/jwt": "^0.8.11",
    "@lindorm-io/key-pair": "^0.6.6",
    "@lindorm-io/koa": "^0.15.1",
    "@lindorm-io/koa-amqp": "^0.0.6",
    "@lindorm-io/koa-axios": "^0.1.22",
    "@lindorm-io/koa-jwt": "^0.5.26",
    "@lindorm-io/koa-keystore": "^0.9.10",
    "@lindorm-io/koa-mongo": "^0.8.14",
    "@lindorm-io/koa-redis": "^0.6.14",
    "@lindorm-io/mongo": "^0.11.3",
    "@lindorm-io/redis": "^0.11.2",
    "@lindorm-io/winston": "^0.4.11",
    "@socket.io/redis-adapter": "^7.2.0",
    "config": "^3.3.6"
  },
  "devDependencies": {
    "@lindorm-io/core-logger": "^0.1.0",
    "@types/config": "^3.3.0",
    "@types/crypto-js": "^4.1.0",
    "@types/express-useragent": "^1.0.2",
    "@types/ioredis": "^4.28.10",
    "@types/jsonwebtoken": "^8.5 .6",
    "@types/koa": "^2.13.5",
    "@types/koa-bodyparser": "^4.3.7",
    "@types/koa-router": "^7.4.4",
    "@types/lodash": "^4.14.182",
    "compd": "^4.1.1",
    "mongodb": "^4.8.1",
    "redis-commands": "^1.7.0"
  }
}
