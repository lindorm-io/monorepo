{
  "name": "@lindorm-io/node-server",
  "description": "Lindorm Node Server",
  "version": "0.5.0",
  "license": "AGPL-3.0-or-later",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rimraf dist && tsc -b ./tsconfig.build.json",
    "test": "yarn test:unit && yarn test:integration",
    "test:integration": "compd --file docker-compose.yml jest --forceExit --config jest.config.integration.js --",
    "test:integration:update": "compd --file docker-compose.yml jest --forceExit --config jest.config.integration.js -u --",
    "test:integration:watch": "compd --file docker-compose.yml jest --forceExit --config jest.config.integration.js --watch --",
    "test:unit": "jest --config jest.config.js --",
    "test:unit:update": "jest --config jest.config.js -u --",
    "test:unit:watch": "jest --config jest.config.js --watch --",
    "test:update": "yarn test:unit:update && yarn test:integration:update",
    "test:watch": "yarn test:unit:watch --",
    "typecheck": "tsc --noEmit --watch",
    "typecheck:ci": "tsc --noEmit"
  },
  "dependencies": {
    "@lindorm-io/amqp": "^0.2.15",
    "@lindorm-io/axios": "^0.6.1",
    "@lindorm-io/jwt": "^0.9.0",
    "@lindorm-io/key-pair": "^0.6.17",
    "@lindorm-io/koa": "^0.16.0",
    "@lindorm-io/koa-amqp": "^0.0.18",
    "@lindorm-io/koa-axios": "^0.1.36",
    "@lindorm-io/koa-jwt": "^0.6.0",
    "@lindorm-io/koa-keystore": "^0.10.0",
    "@lindorm-io/koa-mongo": "^0.9.0",
    "@lindorm-io/koa-redis": "^0.7.0",
    "@lindorm-io/mongo": "^0.12.0",
    "@lindorm-io/redis": "^0.12.0",
    "@lindorm-io/winston": "^0.5.8",
    "@socket.io/redis-adapter": "^8.1.0",
    "config": "^3.3.9"
  },
  "devDependencies": {
    "@lindorm-io/core-logger": "^0.2.4",
    "@types/config": "^3.3.0",
    "@types/crypto-js": "^4.1.0",
    "@types/express-useragent": "^1.0.2",
    "@types/ioredis": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.1",
    "@types/koa": "^2.13.5",
    "@types/koa-bodyparser": "^4.3.10",
    "@types/koa-router": "^7.4.4",
    "compd": "^4.1.1",
    "mongodb": "^5.1.0",
    "redis-commands": "^1.7.0"
  }
}
