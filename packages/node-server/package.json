{
  "name": "@lindorm-io/node-server",
  "description": "Lindorm Node Server",
  "version": "0.8.0",
  "license": "AGPL-3.0-or-later",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rimraf dist && tsc -b ./tsconfig.build.json",
    "test": "jest --watch --",
    "test:ci": "yarn test:unit && yarn test:integration",
    "test:integration": "compd --file docker-compose.yml jest --forceExit --config jest.config.integration.js",
    "test:integration:update": "compd --file docker-compose.yml jest --forceExit --config jest.config.integration.js -u",
    "test:unit": "jest --forceExit",
    "test:unit:update": "jest --forceExit -u",
    "test:update": "yarn test:unit:update && yarn test:integration:update",
    "typecheck": "tsc --noEmit --watch",
    "typecheck:ci": "tsc --noEmit"
  },
  "dependencies": {
    "@lindorm-io/amqp": "^0.3.1",
    "@lindorm-io/axios": "^0.6.6",
    "@lindorm-io/jwt": "^0.10.0",
    "@lindorm-io/key-pair": "^0.7.0",
    "@lindorm-io/koa": "^0.17.1",
    "@lindorm-io/koa-amqp": "^0.1.1",
    "@lindorm-io/koa-axios": "^0.1.41",
    "@lindorm-io/koa-jwt": "^0.6.5",
    "@lindorm-io/koa-keystore": "^0.10.5",
    "@lindorm-io/koa-mongo": "^0.10.1",
    "@lindorm-io/koa-redis": "^0.8.1",
    "@lindorm-io/mongo": "^0.12.4",
    "@lindorm-io/redis": "^0.12.4",
    "@lindorm-io/winston": "^0.5.12",
    "@socket.io/redis-adapter": "^8.2.1",
    "config": "^3.3.9"
  },
  "devDependencies": {
    "@lindorm-io/core-logger": "^0.2.8",
    "@types/config": "^3.3.2",
    "@types/crypto-js": "^4.2.0",
    "@types/express-useragent": "^1.0.4",
    "@types/ioredis": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.4",
    "@types/koa": "^2.13.10",
    "@types/koa-bodyparser": "^4.3.11",
    "@types/koa-router": "^7.4.6",
    "compd": "^4.1.1",
    "mongodb": "^5.1.0",
    "redis-commands": "^1.7.0"
  }
}
