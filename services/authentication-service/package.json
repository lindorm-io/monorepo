{
  "name": "@lindorm-io/authentication-service",
  "description": "Authentication Service for lindorm.io OAuth/OIDC",
  "version": "0.1.0",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist node_modules",
    "generate:config": "yarn generate-typing -f Configuration -o $PWD -r config -w generated",
    "start": "node dist/server/start",
    "start:dev": "compd --file docker-compose.yml nodemon",
    "test": "jest",
    "test:integration": "compd --file docker-compose.yml jest --config jest.config.integration.js",
    "test:update": "jest -u --",
    "test:watch": "jest --watch --",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch"
  },
  "dependencies": {
    "@lindorm-io/axios": "^0.2.8",
    "@lindorm-io/core": "^0.2.12",
    "@lindorm-io/crypto": "^0.1.6",
    "@lindorm-io/entity": "^0.3.0",
    "@lindorm-io/errors": "^0.1.10",
    "@lindorm-io/jwt": "^0.6.2",
    "@lindorm-io/key-pair": "^0.4.0",
    "@lindorm-io/koa": "^0.8.1",
    "@lindorm-io/koa-axios": "^0.0.15",
    "@lindorm-io/koa-bearer-auth": "^0.2.4",
    "@lindorm-io/koa-jwt": "^0.4.5",
    "@lindorm-io/koa-keystore": "^0.5.1",
    "@lindorm-io/koa-mongo": "^0.6.0",
    "@lindorm-io/koa-redis": "^0.4.0",
    "@lindorm-io/mongo": "^0.7.0",
    "@lindorm-io/redis": "^0.5.0",
    "@lindorm-io/winston": "^0.1.9",
    "config": "^3.3.6",
    "date-fns": "^2.27.0",
    "joi": "^17.5.0",
    "js-yaml": "^4.1.0",
    "lodash": "^4.17.21",
    "otplib": "^12.0.1"
  },
  "devDependencies": {
    "@lindorm-io/yaml-typing": "../../packages/yaml-typing",
    "@types/config": "^0.0.41",
    "@types/crypto-js": "^4.1.0",
    "@types/express-useragent": "^1.0.2",
    "@types/ioredis": "^4.28.7",
    "@types/ioredis-mock": "^5.6.0",
    "@types/jest": "^27.4.0",
    "@types/jsonwebtoken": "^8.5.6",
    "@types/koa": "^2.13.4",
    "@types/koa-bodyparser": "^4.3.5",
    "@types/koa-router": "^7.4.4",
    "@types/lodash": "^4.14.178",
    "@types/node": "^17.0.8",
    "@types/supertest": "^2.0.11",
    "compd": "^4.0.0",
    "dotenv": "^10.0.0",
    "jest": "^27.4.7",
    "jest-extended": "^1.2.0",
    "mockdate": "^3.0.5",
    "mongodb": "^4.2.2",
    "supertest": "^6.2.1",
    "ts-jest": "^27.1.2",
    "ts-node": "^10.4.0",
    "typescript": "^4.5.4"
  }
}
