{
  "name": "@lindorm-io/identity-service",
  "description": "Identity Service",
  "version": "0.1.0",
  "license": "AGPL-3.0-or-later",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist node_modules",
    "docker:build": "docker build -t lindorm-io/identity-service:latest .",
    "generate:config": "yarn generate-typing -f Configuration -o $PWD -r config -w src/generated",
    "start": "node dist/server",
    "start:dev": "compd --file docker-compose.yml nodemon",
    "test": "yarn test:unit && yarn test:integration",
    "test:integration": "compd --file docker-compose.yml jest --config jest.config.integration.js --",
    "test:integration:update": "compd --file docker-compose.yml jest --config jest.config.integration.js -u --",
    "test:integration:watch": "compd --file docker-compose.yml jest --config jest.config.integration.js --watch --",
    "test:unit": "jest --config jest.config.js --",
    "test:unit:update": "jest --config jest.config.js -u --",
    "test:unit:watch": "jest --config jest.config.js --watch --",
    "test:update": "yarn test:unit:update && yarn test:integration:update",
    "test:watch": "yarn test:unit:watch --",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "upgrade:dependencies": "yarn upgrade-interactive --latest",
    "verify": "yarn typecheck && yarn test"
  },
  "dependencies": {
    "@lindorm-io/axios": "^0.4.5",
    "@lindorm-io/core": "^0.7.0",
    "@lindorm-io/crypto": "^0.1.17",
    "@lindorm-io/entity": "^0.3.4",
    "@lindorm-io/errors": "^0.1.13",
    "@lindorm-io/koa": "^0.14.0",
    "@lindorm-io/koa-bearer-auth": "^0.3.23",
    "@lindorm-io/koa-keystore": "^0.9.7",
    "@lindorm-io/koa-mongo": "^0.8.11",
    "@lindorm-io/koa-redis": "^0.6.11",
    "@lindorm-io/mongo": "^0.11.0",
    "@lindorm-io/node-server": "^0.4.15",
    "@lindorm-io/redis": "^0.10.1",
    "date-fns": "^2.29.2",
    "joi": "^17.5.0",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@lindorm-io/jwt": "^0.8.8",
    "@lindorm-io/key-pair": "^0.6.3",
    "@lindorm-io/winston": "^0.4.8",
    "@lindorm-io/yaml-typing": "^0.0.9",
    "@types/config": "^3.3.0",
    "@types/crypto-js": "^4.1.0",
    "@types/express-useragent": "^1.0.2",
    "@types/ioredis": "^4.28.10",
    "@types/ioredis-mock": "^5.6.0",
    "@types/jsonwebtoken": "^8.5.9",
    "@types/koa": "^2.13.5",
    "@types/koa-bodyparser": "^4.3.7",
    "@types/koa-router": "^7.4.4",
    "@types/lodash": "^4.14.184",
    "@types/node": "^18.7.15",
    "@types/supertest": "^2.0.12",
    "compd": "^4.1.1",
    "dotenv": "^16.0.2",
    "jest": "^28.1.3",
    "jest-extended": "^3.0.1",
    "mockdate": "^3.0.5",
    "mongodb": "^4.8.0",
    "nock": "^13.2.9",
    "nodemon": "^2.0.19",
    "rimraf": "^3.0.2",
    "supertest": "^6.2.4",
    "ts-jest": "^28.0.7",
    "ts-node": "^10.9.1",
    "typescript": "^4.8.2"
  }
}
