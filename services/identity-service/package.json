{
  "name": "@lindorm-io/identity-service",
  "description": "Identity Service",
  "version": "0.1.0",
  "license": "AGPL-3.0-or-later",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -b -p ./tsconfig.build.json",
    "clean": "rimraf dist node_modules",
    "dev": "nodemon",
    "dev:bootstrap": "echo 'bootstrap'",
    "dev:compd": "compd --file docker-compose.yml nodemon",
    "docker:build": "docker build -t lindorm-io/identity-service:latest .",
    "generate:config": "yarn generate-typing -f Configuration -o $PWD -r config -w src/generated",
    "start": "node dist/server",
    "test": "jest --watch --",
    "test:ci": "yarn test:unit && yarn test:integration",
    "test:integration": "compd --file docker-compose.yml jest --config jest.config.integration.js --forceExit",
    "test:integration:only": "compd --file docker-compose.yml jest --config jest.config.integration.js $1 --watch --detectOpenHandles",
    "test:integration:update": "compd --file docker-compose.yml jest --config jest.config.integration.js -u",
    "test:unit": "jest",
    "test:unit:update": "jest -u",
    "test:update": "yarn test:unit:update && yarn test:integration:update",
    "typecheck": "tsc --noEmit --watch",
    "typecheck:ci": "tsc --noEmit",
    "upgrade:dependencies": "yarn upgrade-interactive --latest",
    "verify": "yarn typecheck:ci && yarn test:ci"
  },
  "dependencies": {
    "@lindorm-io/axios": "^0.6.9",
    "@lindorm-io/common-enums": "^0.1.0",
    "@lindorm-io/core": "^0.8.11",
    "@lindorm-io/crypto": "^0.1.34",
    "@lindorm-io/entity": "^0.3.13",
    "@lindorm-io/errors": "^0.1.21",
    "@lindorm-io/expiry": "^0.2.1",
    "@lindorm-io/koa": "^0.17.4",
    "@lindorm-io/koa-bearer-auth": "^0.4.8",
    "@lindorm-io/koa-keystore": "^0.11.1",
    "@lindorm-io/koa-mongo": "^0.10.4",
    "@lindorm-io/koa-redis": "^0.8.4",
    "@lindorm-io/mongo": "^0.12.5",
    "@lindorm-io/node-server": "^0.9.1",
    "@lindorm-io/random": "^0.2.5",
    "@lindorm-io/redis": "^0.12.5",
    "@lindorm-io/url": "^0.2.14",
    "date-fns": "^2.30.0",
    "joi": "^17.11.0",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@lindorm-io/common-types": "^0.4.0",
    "@lindorm-io/jwt": "^0.11.2",
    "@lindorm-io/key-pair": "^0.8.0",
    "@lindorm-io/winston": "^0.5.13",
    "@lindorm-io/yaml-typing": "^0.0.17",
    "@types/config": "^3.3.3",
    "@types/crypto-js": "^4.2.1",
    "@types/express-useragent": "^1.0.5",
    "@types/ioredis": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/koa": "^2.13.11",
    "@types/koa-bodyparser": "^4.3.12",
    "@types/koa-router": "^7.4.7",
    "@types/lodash": "^4.14.201",
    "@types/node": "^20.9.0",
    "@types/supertest": "^2.0.16",
    "compd": "^4.1.1",
    "dotenv": "^16.3.1",
    "jest": "^29.7.0",
    "jest-extended": "^4.0.2",
    "mockdate": "^3.0.5",
    "mongodb": "^6.2.0",
    "nock": "^13.3.8",
    "nodemon": "^3.0.1",
    "rimraf": "^5.0.5",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  }
}
