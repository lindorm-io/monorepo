{
  "name": "@lindorm-io/oauth-service",
  "description": "OAuth 2.0 / OIDC Service",
  "version": "0.1.0",
  "license": "AGPL-3.0-or-later",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist node_modules",
    "generate:config": "yarn generate-typing -f Configuration -o $PWD -r config -w src/generated",
    "start": "node dist/server",
    "start:dev": "compd --file docker-compose.yml nodemon",
    "test": "jest",
    "test:integration": "compd --file docker-compose.yml jest --config jest.config.integration.js",
    "test:update": "jest -u --",
    "test:watch": "jest --watch --",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "upgrade:dependencies": "yarn upgrade-interactive --latest"
  },
  "dependencies": {
    "@lindorm-io/axios": "^0.2.9",
    "@lindorm-io/core": "^0.2.13",
    "@lindorm-io/crypto": "^0.1.7",
    "@lindorm-io/entity": "^0.3.1",
    "@lindorm-io/errors": "^0.1.11",
    "@lindorm-io/jwt": "^0.6.3",
    "@lindorm-io/key-pair": "^0.4.1",
    "@lindorm-io/koa": "^0.8.4",
    "@lindorm-io/koa-axios": "^0.0.18",
    "@lindorm-io/koa-bearer-auth": "^0.2.7",
    "@lindorm-io/koa-jwt": "^0.4.8",
    "@lindorm-io/koa-keystore": "^0.5.4",
    "@lindorm-io/koa-mongo": "^0.6.3",
    "@lindorm-io/koa-redis": "^0.4.3",
    "@lindorm-io/mongo": "^0.7.1",
    "@lindorm-io/redis": "^0.5.1",
    "@lindorm-io/winston": "^0.1.10",
    "config": "^3.3.6",
    "date-fns": "^2.27.0",
    "joi": "^17.5.0",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@lindorm-io/yaml-typing": "^0.0.2",
    "@types/config": "^0.0.41",
    "@types/crypto-js": "^4.1.0",
    "@types/express-useragent": "^1.0.2",
    "@types/ioredis": "^4.28.10",
    "@types/ioredis-mock": "^5.6.0",
    "@types/jsonwebtoken": "^8.5.6",
    "@types/koa": "^2.13.4",
    "@types/koa-bodyparser": "^4.3.7",
    "@types/koa-router": "^7.4.4",
    "@types/lodash": "^4.14.181",
    "@types/node": "^17.0.23",
    "@types/supertest": "^2.0.12",
    "compd": "^4.0.0",
    "dotenv": "^16.0.0",
    "jest": "^27.4.7",
    "jest-extended": "^2.0.0",
    "mockdate": "^3.0.5",
    "mongodb": "^4.2.2",
    "supertest": "^6.2.1",
    "ts-jest": "^27.1.4",
    "ts-node": "^10.4.0",
    "typescript": "^4.6.3"
  }
}
