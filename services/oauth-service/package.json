{
  "name": "@lindorm-io/oauth-service",
  "description": "OAuth 2.0 / OIDC Service",
  "version": "0.1.0",
  "license": "AGPL-3.0-or-later",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -b -p ./tsconfig.build.json",
    "clean": "rimraf dist node_modules",
    "dev": "nodemon",
    "dev:bootstrap": "ts-node src/bin/bootstrap-dev",
    "dev:compd": "compd --file docker-compose.yml nodemon",
    "dev:generate:admin": "ts-node src/bin/generate-admin-token acbfce9e-072b-450f-b451-5915cdd17a33",
    "docker:build": "docker build -t lindorm-io/oauth-service:latest .",
    "generate:admin": "node dist/bin/generate-admin-token",
    "generate:config": "yarn generate-typing -f Configuration -o $PWD -r config -w src/generated",
    "start": "node dist/server",
    "test": "jest --watch --",
    "test:ci": "yarn test:unit && yarn test:integration",
    "test:integration": "compd --file docker-compose.yml jest --config jest.config.integration.js --forceExit",
    "test:integration:only": "compd --file docker-compose.yml jest --config jest.config.integration.js $1 --watch --detectOpenHandles",
    "test:integration:update": "compd --file docker-compose.yml jest --config jest.config.integration.js -u",
    "test:unit": "jest",
    "test:unit:update": "jest -u",
    "test:update": "yarn test:unit:update && yarn test:integration:update",
    "typecheck": "tsc --noEmit --watch",
    "typecheck:ci": "tsc --noEmit",
    "upgrade:dependencies": "yarn upgrade-interactive --latest",
    "verify": "yarn typecheck:ci && yarn test:ci"
  },
  "dependencies": {
    "@lindorm-io/aes": "^0.3.0",
    "@lindorm-io/axios": "^0.6.18",
    "@lindorm-io/case": "^0.2.0",
    "@lindorm-io/common-enums": "^0.1.2",
    "@lindorm-io/core": "^0.8.11",
    "@lindorm-io/crypto": "^0.3.2",
    "@lindorm-io/entity": "^0.3.14",
    "@lindorm-io/errors": "^0.1.21",
    "@lindorm-io/expiry": "^0.2.1",
    "@lindorm-io/jwk": "^0.2.0",
    "@lindorm-io/jwt": "^0.13.0",
    "@lindorm-io/keystore": "^0.1.0",
    "@lindorm-io/koa": "^0.17.11",
    "@lindorm-io/koa-bearer-auth": "^0.4.17",
    "@lindorm-io/koa-jwt": "^0.6.17",
    "@lindorm-io/koa-keystore": "^0.11.12",
    "@lindorm-io/koa-mongo": "^0.10.12",
    "@lindorm-io/koa-redis": "^0.8.12",
    "@lindorm-io/mongo": "^0.12.6",
    "@lindorm-io/node-pkce": "^0.1.14",
    "@lindorm-io/node-server": "^0.9.13",
    "@lindorm-io/random": "^0.2.6",
    "@lindorm-io/redis": "^0.12.6",
    "@lindorm-io/url": "^0.2.18",
    "@lindorm-io/winston": "^0.5.13",
    "date-fns": "^3.2.0",
    "joi": "^17.11.0",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@lindorm-io/common-types": "^0.5.2",
    "@lindorm-io/yaml-typing": "^0.0.17",
    "@types/config": "^3.3.3",
    "@types/crypto-js": "^4.2.1",
    "@types/express-useragent": "^1.0.5",
    "@types/ioredis": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/koa": "^2.14.0",
    "@types/koa-bodyparser": "^4.3.12",
    "@types/koa-router": "^7.4.8",
    "@types/lodash": "^4.14.202",
    "@types/node": "^20.11.4",
    "@types/supertest": "^6.0.2",
    "compd": "^4.1.1",
    "dotenv": "^16.3.1",
    "himalaya": "^1.1.0",
    "jest": "^29.7.0",
    "jest-extended": "^4.0.2",
    "jsonwebtoken": "^9.0.2",
    "mockdate": "^3.0.5",
    "mongodb": "^6.3.0",
    "nock": "^13.5.0",
    "nodemon": "^3.0.2",
    "rimraf": "^5.0.5",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
