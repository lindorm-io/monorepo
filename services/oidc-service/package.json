{
  "name": "@lindorm-io/oidc-service",
  "description": "OIDC Service",
  "version": "0.1.0",
  "license": "AGPL-3.0-or-later",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -b -p ./tsconfig.build.json",
    "clean": "rimraf dist node_modules",
    "dev": "nodemon",
    "dev:bootstrap": "echo 'bootstrap'",
    "dev:compd": "compd --file docker-compose.yml nodemon",
    "docker:build": "docker build -t lindorm-io/oidc-service:latest .",
    "generate:config": "yarn generate-typing -f Configuration -o $PWD -r config -w src/generated",
    "start": "node dist/server",
    "test": "jest --watch --",
    "test:ci": "yarn test:unit && yarn test:integration",
    "test:integration": "compd --file docker-compose.yml jest --config jest.config.integration.js --forceExit",
    "test:integration:update": "compd --file docker-compose.yml jest --config jest.config.integration.js -u",
    "test:unit": "jest",
    "test:unit:update": "jest -u",
    "test:update": "yarn test:unit:update && yarn test:integration:update",
    "typecheck": "tsc --noEmit --watch",
    "typecheck:ci": "tsc --noEmit",
    "upgrade:dependencies": "yarn upgrade-interactive --latest",
    "verify": "yarn typecheck && yarn test"
  },
  "dependencies": {
    "@lindorm-io/axios": "^0.6.5",
    "@lindorm-io/common-types": "^0.3.0",
    "@lindorm-io/core": "^0.8.11",
    "@lindorm-io/entity": "^0.3.12",
    "@lindorm-io/errors": "^0.1.20",
    "@lindorm-io/expiry": "^0.1.6",
    "@lindorm-io/koa": "^0.17.0",
    "@lindorm-io/koa-bearer-auth": "^0.4.4",
    "@lindorm-io/koa-keystore": "^0.10.4",
    "@lindorm-io/koa-redis": "^0.8.0",
    "@lindorm-io/node-pkce": "^0.1.7",
    "@lindorm-io/node-server": "^0.7.0",
    "@lindorm-io/random": "^0.2.3",
    "@lindorm-io/redis": "^0.12.3",
    "@lindorm-io/url": "^0.2.10",
    "joi": "^17.9.1",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@lindorm-io/jwt": "^0.9.3",
    "@lindorm-io/key-pair": "^0.6.20",
    "@lindorm-io/winston": "^0.5.11",
    "@lindorm-io/yaml-typing": "^0.0.16",
    "@types/config": "^3.3.0",
    "@types/crypto-js": "^4.1.0",
    "@types/express-useragent": "^1.0.2",
    "@types/ioredis": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.1",
    "@types/koa": "^2.13.6",
    "@types/koa-bodyparser": "^4.3.10",
    "@types/koa-router": "^7.4.4",
    "@types/lodash": "^4.14.192",
    "@types/node": "^18.15.11",
    "@types/supertest": "^2.0.12",
    "compd": "^4.1.1",
    "dotenv": "^16.0.3",
    "jest": "^29.5.0",
    "jest-extended": "^3.2.4",
    "mockdate": "^3.0.5",
    "mongodb": "^5.1.0",
    "nock": "^13.3.0",
    "nodemon": "^2.0.22",
    "rimraf": "^4.4.1",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.3"
  }
}
