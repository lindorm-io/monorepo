{
  "name": "@lindorm-io/oidc-service",
  "description": "OIDC Service",
  "version": "0.1.0",
  "license": "AGPL-3.0-or-later",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist node_modules",
    "dev": "nodemon",
    "dev:bootstrap": "echo 'bootstrap'",
    "docker:build": "docker build -t lindorm-io/oidc-service:latest .",
    "generate:config": "yarn generate-typing -f Configuration -o $PWD -r config -w src/generated",
    "start": "node dist/server",
    "start:dev": "compd --file docker-compose.yml nodemon",
    "test": "yarn test:unit && yarn test:integration",
    "test:integration": "compd --file docker-compose.yml jest --forceExit --config jest.config.integration.js --",
    "test:integration:update": "compd --file docker-compose.yml jest --forceExit --config jest.config.integration.js -u --",
    "test:integration:watch": "compd --file docker-compose.yml jest --forceExit --config jest.config.integration.js --watch --",
    "test:unit": "jest --config jest.config.js --",
    "test:unit:update": "jest --config jest.config.js -u --",
    "test:unit:watch": "jest --config jest.config.js --watch --",
    "test:update": "yarn test:unit:update && yarn test:integration:update",
    "test:watch": "yarn test:unit:watch --",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "upgrade:dependencies": "yarn upgrade-interactive --latest",
    "verify": "yarn typecheck && yarn test"
  },
  "dependencies": {
    "@lindorm-io/axios": "^0.5.10",
    "@lindorm-io/core": "^0.8.7",
    "@lindorm-io/entity": "^0.3.7",
    "@lindorm-io/errors": "^0.1.15",
    "@lindorm-io/expiry": "^0.1.1",
    "@lindorm-io/koa": "^0.15.11",
    "@lindorm-io/koa-bearer-auth": "^0.3.36",
    "@lindorm-io/koa-keystore": "^0.9.22",
    "@lindorm-io/koa-redis": "^0.6.24",
    "@lindorm-io/node-pkce": "^0.1.2",
    "@lindorm-io/node-server": "^0.4.30",
    "@lindorm-io/random": "^0.1.2",
    "@lindorm-io/redis": "^0.11.12",
    "@lindorm-io/url": "^0.2.5",
    "joi": "^17.7.0",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@lindorm-io/jwt": "^0.8.21",
    "@lindorm-io/key-pair": "^0.6.15",
    "@lindorm-io/winston": "^0.5.6",
    "@lindorm-io/yaml-typing": "^0.0.12",
    "@types/config": "^3.3.0",
    "@types/crypto-js": "^4.1.0",
    "@types/express-useragent": "^1.0.2",
    "@types/ioredis": "^5.0.0",
    "@types/ioredis-mock": "^8.2.1",
    "@types/jsonwebtoken": "^9.0.1",
    "@types/koa": "^2.13.5",
    "@types/koa-bodyparser": "^4.3.10",
    "@types/koa-router": "^7.4.4",
    "@types/lodash": "^4.14.191",
    "@types/node": "^18.11.18",
    "@types/supertest": "^2.0.12",
    "compd": "^4.1.1",
    "dotenv": "^16.0.3",
    "jest": "^29.4.1",
    "jest-extended": "^3.2.3",
    "mockdate": "^3.0.5",
    "mongodb": "^5.0.0",
    "nock": "^13.3.0",
    "nodemon": "^2.0.20",
    "rimraf": "^4.1.2",
    "supertest": "^6.3.3",
    "ts-jest": "^29.0.5",
    "ts-node": "^10.9.1",
    "typescript": "^4.9.5"
  }
}
