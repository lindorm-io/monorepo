{
  "name": "@lindorm-io/device-service",
  "description": "Device Service",
  "version": "0.1.0",
  "license": "AGPL-3.0-or-later",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist node_modules",
    "generate:config": "yarn generate-typing -f Configuration -o $PWD -r config -w src/generated",
    "start": "node dist/server",
    "start:dev": "compd --file docker-compose.yml nodemon",
    "test": "yarn test:unit && yarn test:integration",
    "test:integration": "compd --file docker-compose.yml jest --config jest.config.integration.js --",
    "test:integration:update": "compd --file docker-compose.yml jest --config jest.config.integration.js -u --",
    "test:integration:watch": "compd --file docker-compose.yml jest --config jest.config.integration.js --watch --",
    "test:unit": "jest --config jest.config.js --",
    "test:unit:update": "jest --config jest.config.js -u --",
    "test:unit:watch": "jest --config jest.config.js --watch --",
    "test:update": "yarn test:unit:update && yarn test:integration:update",
    "test:watch": "yarn test:unit:watch --",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "upgrade:dependencies": "yarn upgrade-interactive --latest",
    "verify": "yarn typecheck && yarn test"
  },
  "dependencies": {
    "@lindorm-io/axios": "^0.3.3",
    "@lindorm-io/core": "^0.4.0",
    "@lindorm-io/crypto": "^0.1.10",
    "@lindorm-io/entity": "^0.3.3",
    "@lindorm-io/errors": "^0.1.13",
    "@lindorm-io/jwt": "^0.6.11",
    "@lindorm-io/key-pair": "^0.4.4",
    "@lindorm-io/koa": "^0.12.7",
    "@lindorm-io/koa-axios": "^0.1.7",
    "@lindorm-io/koa-bearer-auth": "^0.3.7",
    "@lindorm-io/koa-jwt": "^0.5.7",
    "@lindorm-io/koa-keystore": "^0.7.0",
    "@lindorm-io/koa-mongo": "^0.8.0",
    "@lindorm-io/koa-redis": "^0.6.0",
    "@lindorm-io/mongo": "^0.8.0",
    "@lindorm-io/node-server": "^0.3.0",
    "@lindorm-io/redis": "^0.7.0",
    "@lindorm-io/winston": "^0.3.0",
    "joi": "^17.5.0",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@lindorm-io/yaml-typing": "^0.0.5",
    "@types/config": "^0.0.41",
    "@types/crypto-js": "^4.1.1",
    "@types/express-useragent": "^1.0.2",
    "@types/ioredis": "^4.28.7",
    "@types/ioredis-mock": "^5.6.0",
    "@types/jsonwebtoken": "^8.5.6",
    "@types/koa": "^2.13.4",
    "@types/koa-bodyparser": "^4.3.5",
    "@types/koa-router": "^7.4.4",
    "@types/lodash": "^4.14.182",
    "@types/node": "^17.0.34",
    "@types/supertest": "^2.0.11",
    "compd": "^4.1.1",
    "dotenv": "^16.0.1",
    "jest": "^28.1.0",
    "jest-extended": "^2.0.0",
    "mockdate": "^3.0.5",
    "mongodb": "^4.2.2",
    "nock": "^13.2.4",
    "nodemon": "^2.0.16",
    "rimraf": "^3.0.2",
    "supertest": "^6.2.3",
    "ts-jest": "^28.0.2",
    "ts-node": "^10.4.0",
    "typescript": "^4.6.4"
  }
}
