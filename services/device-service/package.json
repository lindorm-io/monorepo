{
  "name": "@lindorm-io/device-service",
  "description": "Device Service",
  "version": "0.1.0",
  "license": "AGPL-3.0-or-later",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -b -p ./tsconfig.build.json",
    "clean": "rimraf dist node_modules",
    "dev": "nodemon",
    "dev:bootstrap": "echo 'bootstrap'",
    "dev:compd": "compd --file docker-compose.yml nodemon",
    "dev:generate:confirmation-token": "ts-node src/bin/generate-confirmation-token",
    "dev:generate:device": "ts-node src/bin/generate-device",
    "docker:build": "docker build -t lindorm-io/device-service:latest .",
    "generate:config": "yarn generate-typing -f Configuration -o $PWD -r config -w src/generated",
    "start": "node dist/server",
    "test": "jest --watch --",
    "test:ci": "yarn test:unit && yarn test:integration",
    "test:integration": "compd --file docker-compose.yml jest --config jest.config.integration.js --forceExit",
    "test:integration:update": "compd --file docker-compose.yml jest --config jest.config.integration.js -u",
    "test:unit": "jest",
    "test:unit:update": "jest -u",
    "test:update": "yarn test:unit:update && yarn test:integration:update",
    "typecheck": "tsc --noEmit --watch",
    "typecheck:ci": "tsc --noEmit",
    "upgrade:dependencies": "yarn upgrade-interactive --latest",
    "verify": "yarn typecheck && yarn test"
  },
  "dependencies": {
    "@lindorm-io/axios": "^0.6.7",
    "@lindorm-io/common-enums": "^0.0.1",
    "@lindorm-io/core": "^0.8.11",
    "@lindorm-io/crypto": "^0.1.34",
    "@lindorm-io/entity": "^0.3.13",
    "@lindorm-io/errors": "^0.1.21",
    "@lindorm-io/expiry": "^0.2.1",
    "@lindorm-io/jwt": "^0.11.0",
    "@lindorm-io/key-pair": "^0.7.1",
    "@lindorm-io/koa": "^0.17.2",
    "@lindorm-io/koa-axios": "^0.1.42",
    "@lindorm-io/koa-bearer-auth": "^0.4.6",
    "@lindorm-io/koa-jwt": "^0.6.6",
    "@lindorm-io/koa-keystore": "^0.10.6",
    "@lindorm-io/koa-mongo": "^0.10.2",
    "@lindorm-io/koa-redis": "^0.8.2",
    "@lindorm-io/mongo": "^0.12.5",
    "@lindorm-io/node-server": "^0.8.1",
    "@lindorm-io/random": "^0.2.5",
    "@lindorm-io/redis": "^0.12.5",
    "@lindorm-io/winston": "^0.5.13",
    "date-fns": "^2.30.0",
    "joi": "^17.11.0",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@lindorm-io/common-types": "^0.3.2",
    "@lindorm-io/yaml-typing": "^0.0.17",
    "@types/config": "^3.3.3",
    "@types/crypto-js": "^4.2.1",
    "@types/express-useragent": "^1.0.4",
    "@types/ioredis": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.4",
    "@types/koa": "^2.13.10",
    "@types/koa-bodyparser": "^4.3.11",
    "@types/koa-router": "^7.4.6",
    "@types/lodash": "^4.14.200",
    "@types/node": "^20.8.10",
    "@types/supertest": "^2.0.15",
    "compd": "^4.1.1",
    "dotenv": "^16.3.1",
    "jest": "^29.7.0",
    "jest-extended": "^4.0.2",
    "mockdate": "^3.0.5",
    "mongodb": "^6.2.0",
    "nock": "^13.3.8",
    "nodemon": "^3.0.1",
    "rimraf": "^5.0.5",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  }
}
