{
  "name": "@lindorm/monorepo",
  "version": "0.0.0",
  "license": "AGPL-3.0-or-later",
  "author": "Jonn Nilsson",
  "repository": "https://github.com/lindorm-io/monorepo",
  "bugs": "https://github.com/lindorm-io/monorepo/issues",
  "scripts": {
    "build": "lerna run build",
    "init": "ts-node ./.scripts/initialise-package.ts && npm i",
    "lint": "eslint packages/*/src/ && node scripts/audit/integration-script-guard.mjs",
    "prepare": "husky",
    "prettier": "prettier --write packages/*/src/",
    "release": "lerna publish --yes",
    "sync:peers": "syncpack lint",
    "sync:peers:fix": "syncpack fix && syncpack fix",
    "test": "npm run test:unit && composed --file docker-compose.yml npm run test:integration",
    "test:unit": "lerna run test:unit",
    "test:integration": "lerna run test:integration",
    "typecheck": "lerna run typecheck",
    "update": "ncu -i",
    "update:auto": "ncu -u && lerna run update:auto && npm install && npm audit fix"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint/js": "^10.0.1",
    "@swc/core": "^1.15.30",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-prettier": "^5.5.5",
    "fs-extra": "^11.3.4",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lerna": "^9.0.7",
    "lint-staged": "^16.4.0",
    "mockdate": "^3.0.5",
    "nock": "^14.0.12",
    "npm-check-updates": "^20.0.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "syncpack": "^14.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.4"
  },
  "optionalDependencies": {
    "@nx/nx-darwin-arm64": "22.5.4",
    "@nx/nx-darwin-x64": "22.5.4",
    "@nx/nx-linux-x64-gnu": "22.5.4",
    "@nx/nx-win32-x64-msvc": "22.5.4"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "workspaces": [
    "packages/*"
  ]
}
