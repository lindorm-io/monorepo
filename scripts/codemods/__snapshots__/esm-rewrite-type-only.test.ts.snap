exports[`applyTypeOnlyFixes handles aliased named import (foo as Bar) 1`] = `
"import type { foo as Bar } from "./foo";
"
`;

exports[`applyTypeOnlyFixes inline-annotates a single type-only specifier in a mixed import 1`] = `
