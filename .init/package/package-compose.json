{
  "name": "@lindorm/{{NAME}}",
  "version": "0.0.0",
  "license": "AGPL-3.0-or-later",
  "author": "Jonn Nilsson",
  "repository": {
    "url": "https://github.com/lindorm-io/monorepo",
    "directory": "packages/{{NAME}}"
  },
  "bugs": "https://github.com/lindorm-io/monorepo/issues",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "imports": {
    "#internal/*": "./dist/internal/*.js"
  },
  "scripts": {
    "build": "rimraf dist && tsc -b ./tsconfig.build.json",
    "example": "ts-node example",
    "prettier": "prettier --write ./src/*",
    "test": "compd --file docker-compose.yml jest -i",
    "test:ci": "jest -i",
    "test:update": "compd --file docker-compose.yml jest -i -u",
    "test:watch": "compd --file docker-compose.yml jest -i --watch",
    "typecheck": "tsc",
    "typecheck:watch": "tsc -w",
    "update": "ncu -i",
    "update:auto": "ncu -u",
    "verify": "npm run typecheck; npm run build; npm test"
  },
  "dependencies": {},
  "devDependencies": {},
  "peerDependencies": {}
}
